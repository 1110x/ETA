<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lottie="using:Avalonia.Labs.Lottie"
    xmlns:models="using:ETA.Models"
    x:Class="ETA.Views.Page1"
    Width="1600"
    Height="900"
    Icon="avares://ETA/Assets/ETA.ico"
    Title="ETA Water Analysis Center">

    <Grid ColumnDefinitions="200,*">

        <!-- 왼쪽 사이드바 (변경 없음) -->
        <Border Grid.Column="0"
            Background="#252527"
            Padding="10">

            <Grid RowDefinitions="*,220">

                <!-- 메뉴 버튼들 -->
                <StackPanel Grid.Row="0" Spacing="0">
                    <StackPanel.Styles>
                        <Style Selector="Button">
                            <Setter Property="FontSize" Value="14" />
                          <!--Setter Property="FontFamily"
                                Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R" /-->
                            <Setter Property="Height" Value="40" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="Background" Value="#252527" />
                            <Setter Property="Foreground" Value="#bbb5b5" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="4" />
                        </Style>

                        <Style Selector="Button StackPanel">
                            <Setter Property="Orientation" Value="Horizontal" />
                            <Setter Property="Spacing" Value="0" />
                        </Style>

                        <Style Selector="Button Image">
                            <Setter Property="Width" Value="26" />
                            <Setter Property="Height" Value="26" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>

                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#444444" />
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="Width" Value="300" />
                        </Style>

                        <Style Selector="Button:pointerover TextBlock">
                            <Setter Property="Foreground" Value="#40e248" />
                        </Style>
                    </StackPanel.Styles>

                    <Button Click="Contract_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A1.png" />
                            <TextBlock Text="업체등록" />
                        </StackPanel>
                    </Button>

                    <Button Click="Quotation_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A2.png" />
                            <TextBlock Text="분석단가" />
                        </StackPanel>
                    </Button>

                    <Button>
                        <StackPanel>
                            <Image Source="/Assets/icons/A3.png" />
                            <TextBlock Text="의뢰등록" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A4.png" />
                            <TextBlock Text="분석관리" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A5.png" />
                            <TextBlock Text="측정인" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A6.png" />
                            <TextBlock Text="채수" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A7.png" />
                            <TextBlock Text="거래명세서" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A8.png" />
                            <TextBlock Text="사업소 의뢰" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A9.png" />
                            <TextBlock Text="분석담당자" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A10.png" />
                            <TextBlock Text="시험기록부" />
                        </StackPanel>
                    </Button>

                    <Button Click="Analysis_Click">
                        <StackPanel>
                            <Image Source="/Assets/icons/A11.png" />
                            <TextBlock Text="차량운행일지" />
                        </StackPanel>
                    </Button>

                    <Button Click="Admin_Click">
                        <StackPanel>
                            <lottie:Lottie x:Name="lottieRabbit2"
                                Width="24" Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Path="avares://ETA/Assets/Admin.json"
                                AutoPlay="True"
                                RepeatCount="-1"
                                Stretch="UniformToFill" />
                            <TextBlock Text="관리자" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 로키 그림 -->
                <Border Grid.Row="1" Margin="5" Background="#252527" CornerRadius="12">
                    <lottie:Lottie x:Name="lottieRabbit"
                        Width="160" Height="160"
                        Path="avares://ETA/Assets/Dancecat.json"
                        AutoPlay="True" RepeatCount="-1" Stretch="UniformToFill" />
                </Border>
            </Grid>
        </Border>

        <!-- 메인 영역 -->
        <Grid Grid.Column="1" Background="#444444">

            <!-- 기본 화면 -->
            <StackPanel x:Name="MainPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="10"
                IsVisible="True">
                <lottie:Lottie Width="300" Height="300"
                    Path="avares://ETA/Assets/Dog.json"
                    AutoPlay="True" RepeatCount="-1" Stretch="Uniform" />
                <TextBlock Text="Poodig Poodig Poo Poo Poo Poooding~"
                    FontSize="36"
                    HorizontalAlignment="Center" />
            </StackPanel>

            <!-- 분석관리 그리드 -->
             
            <DataGrid x:Name="AnalysisGrid"
                Margin="20"
                IsVisible="False"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                SelectionMode="Extended"
                Background="#5f5a5a"
                BorderBrush="#5f5a5a"
                BorderThickness="1"
                x:CompileBindings="False">

                <DataGrid.Styles>
                    <!-- 기존 스타일 그대로 -->
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Background" Value="#5e5e5e" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="BorderBrush" Value="#424242" />
                    </Style>
                    <Style Selector="DataGridCell TextBlock">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R" />
                        <Setter Property="FontSize" Value="14" />
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="분류" Binding="{Binding Category}" Width="150" />
                    <DataGridTextColumn Header="분석항목" Binding="{Binding Analyte}" Width="200" />
                    <DataGridTextColumn Header="특정/수질" Binding="{Binding Parts}" Width="120" />
                    <DataGridTextColumn Header="소수점" Binding="{Binding DecimalPlaces}" Width="100" />
                    <DataGridTextColumn Header="단위" Binding="{Binding unit}" Width="80" />
                    <DataGridTextColumn Header="시험법" Binding="{Binding ES}" Width="120" />
                    <DataGridTextColumn Header="ES.No" Binding="{Binding Method}" Width="300" />
                    <DataGridTextColumn Header="분석장비" Binding="{Binding instrument}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 업체관리 그리드 (AnalysisGrid와 같은 레벨로 이동) -->
            <DataGrid x:Name="ContractGrid"
                Margin="20"
                IsVisible="False"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                SelectionMode="Extended"
                Background="#5f5a5a"
                BorderBrush="#5f5a5a"
                BorderThickness="1"
                x:CompileBindings="False">

                <DataGrid.Styles>
                    <!-- 동일한 스타일 복사 -->
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Background" Value="#5e5e5e" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="BorderBrush" Value="#424242" />
                    </Style>
                    <Style Selector="DataGridCell TextBlock">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R" />
                        <Setter Property="FontSize" Value="14" />
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="업체명" Binding="{Binding C_CompanyName}" Width="220" />
                    <DataGridTextColumn Header="약칭" Binding="{Binding C_Abbreviation}" Width="120" />
                    <DataGridTextColumn Header="계약구분" Binding="{Binding C_ContractType}" Width="130" />
                    <DataGridTextColumn Header="계약시작" Binding="{Binding C_ContractStart, StringFormat={}{0:yyyy-MM-dd}}" Width="110" />
                    <DataGridTextColumn Header="계약종료" Binding="{Binding C_ContractEnd, StringFormat={}{0:yyyy-MM-dd}}" Width="110" />
                    <DataGridTextColumn Header="계약일수" Binding="{Binding C_ContractDays}" Width="90" />
                    <DataGridTextColumn Header="계약금액(VAT별도)" Binding="{Binding C_ContractAmountVATExcluded, StringFormat={}{0:N0}}" Width="140" />
                    <DataGridTextColumn Header="주소" Binding="{Binding C_Address}" Width="250" />
                    <DataGridTextColumn Header="대표자" Binding="{Binding C_Representative}" Width="120" />
                    <DataGridTextColumn Header="시설별" Binding="{Binding C_FacilityType}" Width="100" />
                    <DataGridTextColumn Header="종류별" Binding="{Binding C_CategoryType}" Width="100" />
                    <DataGridTextColumn Header="주생산품" Binding="{Binding C_MainProduct}" Width="180" />
                    <DataGridTextColumn Header="담당자" Binding="{Binding C_ContactPerson}" Width="110" />
                    <DataGridTextColumn Header="연락처" Binding="{Binding C_PhoneNumber}" Width="130" />
                    <DataGridTextColumn Header="이메일" Binding="{Binding C_Email}" Width="200" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 견적정보 그리드 (분석단가) -->
            <DataGrid x:Name="QuotationGrid"
                Margin="20"
                IsVisible="False"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                SelectionMode="Extended"
                Background="#5f5a5a"
                BorderBrush="#5f5a5a"
                BorderThickness="1"
                x:CompileBindings="False">

                <DataGrid.Styles>
                    <!-- AnalysisGrid와 동일한 스타일 복사 -->
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Background" Value="#5e5e5e" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                        <Setter Property="FontSize" Value="16" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="BorderBrush" Value="#424242" />
                    </Style>
                    <Style Selector="DataGridCell TextBlock">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R" />
                        <Setter Property="FontSize" Value="14" />
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="항목구분" Binding="{Binding Category}" Width="120" />
                    <DataGridTextColumn Header="항목명" Binding="{Binding Analyte}" Width="180" />
                    <DataGridTextColumn Header="100% FS" Binding="{Binding FS100, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="100% FS+" Binding="{Binding FS100Plus, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="56% FS" Binding="{Binding FS56, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="56% NFS" Binding="{Binding NFS56, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="55% FS" Binding="{Binding FS55, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="52% FS" Binding="{Binding FS52, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="52% FS-HN" Binding="{Binding FSHN52, StringFormat=N0}" Width="110" />
                    <DataGridTextColumn Header="50% NFS" Binding="{Binding NFS50, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="45% NFS" Binding="{Binding NFS45, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="39% NFS" Binding="{Binding NFS39, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="36% NFS" Binding="{Binding NFS36, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="36% NFS RE" Binding="{Binding NFS36RE, StringFormat=N0}" Width="110" />
                    <DataGridTextColumn Header="25% FS" Binding="{Binding FS25, StringFormat=N0}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 필요하면 ListBox 등 다른 컨텐츠도 같은 레벨에 추가 -->

        </Grid>

    </Grid>
</Window>