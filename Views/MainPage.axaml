<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lottie="using:Avalonia.Labs.Lottie"
        x:Class="ETA.Views.MainPage"
        TransparencyLevelHint="AcrylicBlur"
        Width="1600" Height="900"
        Icon="avares://ETA/Assets/icons/ETA.ico"
        Title="ETA Water Analysis Center">

    <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
         м „м—ӯ н…Ңл§Ҳ лҰ¬мҶҢмҠӨ
         isDark=True  вҶ’ Dark  нҢ”л ҲнҠё
         isDark=False вҶ’ Light нҢ”л ҲнҠё
         лӘЁл“  мғүмғҒмқҖ DynamicResource лЎң м°ёмЎ° вҶ’ ApplyTheme() н•ң лІҲмңјлЎң м „мІҙ м Ғмҡ©
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
    <Window.Resources>
        <!-- в”Җв”Җ кёҖмһҗ нҒ¬кё° лӢЁкі„ (мҠ¬лқјмқҙлҚ” ApplyFontScale м—җм„ң лҸҷм Ғ к°ұмӢ , scale=1.0 кё°мӨҖ) в”Җв”Җ -->
        <x:Double x:Key="FontSizeXS">9</x:Double>
        <x:Double x:Key="FontSizeSM">10</x:Double>
        <x:Double x:Key="FontSizeBase">11</x:Double>
        <x:Double x:Key="FontSizeMD">12</x:Double>
        <x:Double x:Key="FontSizeLG">13</x:Double>
        <x:Double x:Key="FontSizeXL">14</x:Double>
        <x:Double x:Key="FontSizeTitle">22</x:Double>
        <x:Double x:Key="FontSizeHuge">28</x:Double>

        <!-- в”Җв”Җ лӢӨнҒ¬ кё°ліёк°’ (мҪ”л“ңм—җм„ң LightлЎң көҗмІҙ) в”Җв”Җ -->
        <SolidColorBrush x:Key="AppBg"            Color="#1e1e26"/>
        <SolidColorBrush x:Key="PanelBg"          Color="#39383f"/>
        <SolidColorBrush x:Key="PanelInnerBg"     Color="#2d2d35"/>
        <SolidColorBrush x:Key="MenuBarBg"        Color="#444444"/>
        <SolidColorBrush x:Key="MenuItemBg"       Color="#444444"/>
        <SolidColorBrush x:Key="MenuItemHover"    Color="#012800"/>
        <SolidColorBrush x:Key="SubMenuBg"        Color="#012800"/>
        <SolidColorBrush x:Key="SubMenuItemBg"    Color="#444444"/>  <!-- вҳ… нҶөмқј -->
        <SolidColorBrush x:Key="SubMenuItemHover" Color="#023d00"/>
        <SolidColorBrush x:Key="SubBtnBg"         Color="#342f2f"/>
        <SolidColorBrush x:Key="SubBtnHover"      Color="#012800"/>
        <SolidColorBrush x:Key="SplitterColor"    Color="#020202"/>
        <SolidColorBrush x:Key="AppFg"            Color="#ffffff"/>
        <SolidColorBrush x:Key="FgMuted"          Color="#aaaaaa"/>
        <SolidColorBrush x:Key="FgHover"          Color="#fd0f0f"/>
        <SolidColorBrush x:Key="TreeFg"           Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TreeSelBg"        Color="#014a00"/>
        <SolidColorBrush x:Key="TreeSelFg"        Color="#ffffff"/>
        <SolidColorBrush x:Key="GridHeaderBg"     Color="#2a2a32"/>
        <SolidColorBrush x:Key="GridRowBg"        Color="#35343c"/>
        <SolidColorBrush x:Key="GridRowAltBg"     Color="#2d2d35"/>
        <SolidColorBrush x:Key="InputBg"          Color="#2d2d35"/>
        <SolidColorBrush x:Key="InputBorder"      Color="#555566"/>
        <SolidColorBrush x:Key="InputFg"          Color="#e8e8e8"/>
    </Window.Resources>

    <!-- в”Җв”Җ м „м—ӯ мҠӨнғҖмқј (лӘЁл“  н•ҳмң„ м»ЁнҠёлЎӨм—җ м Ғмҡ©) в”Җв”Җ -->
    <Window.Styles>
        <!-- TextBlock -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource AppFg}"/>
            <Setter Property="FontFamily"  Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"    Value="{DynamicResource FontSizeLG}"/>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background"   Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"   Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource InputBorder}"/>
            <Setter Property="FontFamily"   Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"     Value="{DynamicResource FontSizeLG}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="FontFamily"  Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"    Value="{DynamicResource FontSizeLG}"/>
        </Style>

        <!-- DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="Background"      Value="{DynamicResource GridRowBg}"/>
            <Setter Property="RowBackground"   Value="{DynamicResource GridRowBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AppFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeMD}"/>
        </Style>
        <!-- м§қмҲҳ н–ү көҗлҢҖ мғүмғҒ (AvaloniaлҠ” AlternatingRowBackground м—ҶмқҢ) -->
        <Style Selector="DataGridRow:nth-child(even)">
            <Setter Property="Background" Value="{DynamicResource GridRowAltBg}"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="8,4"/>
        </Style>

        <!-- TreeView -->
        <Style Selector="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}"/>
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeLG}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444455"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a4a1a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#252535" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <!-- CheckBox / RadioButton -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeLG}"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeLG}"/>
        </Style>

        <!-- Label -->
        <Style Selector="Label">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
        </Style>

        <!-- в•җв•җ мғҒлӢЁ л©”мқё л©”лүҙл°” лІ„нҠј(MenuItem) в•җв•җ -->
        <Style Selector="MenuItem">
            <Setter Property="FontSize"    Value="{DynamicResource FontSizeLG}"/>
            <Setter Property="FontFamily"  Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="Height"      Value="25"/>
            <Setter Property="Padding"     Value="18,0"/>
            <Setter Property="Background"  Value="{DynamicResource MenuItemBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AppFg}"/>
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background"  Value="{DynamicResource MenuItemHover}"/>
        </Style>
        <Style Selector="MenuItem:pointerover > TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
        </Style>

        <!-- вҳ… м„ңлёҢл©”лүҙ нҢқм—… л°°кІҪ -->
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background"       Value="{DynamicResource SubMenuBg}"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="5,5"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="{DynamicResource AppFg}"/>
        </Style>

        <!-- вҳ… м„ңлёҢл©”лүҙ н•ӯлӘ©: SubMenuItemBg лЎң нҶөмқј (мң„м•„лһҳ мғүмғҒ м°Ёмқҙ н•ҙмҶҢ) -->
        <Style Selector="MenuItem MenuItem">
            <Setter Property="Background"  Value="{DynamicResource SubMenuItemBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AppFg}"/>
            <Setter Property="Padding"     Value="5,5"/>
            <Setter Property="MinHeight"   Value="36"/>
        </Style>
        <Style Selector="MenuItem MenuItem:pointerover">
            <Setter Property="Background"  Value="{DynamicResource SubMenuItemHover}"/>
        </Style>
        <Style Selector="MenuItem MenuItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
        </Style>
        <Style Selector="MenuItem MenuItem:pointerover TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgHover}"/>
        </Style>
        <Style Selector="MenuFlyoutPresenter TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
        </Style>

        <!-- в•җв•җ м„ңлёҢл©”лүҙ лІ„нҠј (SubMenu нҲҙл°”) в•җв•җ -->
        <Style Selector="StackPanel#SubMenu > Button">
            <Setter Property="FontSize"                   Value="{DynamicResource FontSizeLG}"/>
            <Setter Property="FontFamily"                 Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="Height"                     Value="25"/>
            <Setter Property="CornerRadius"               Value="4"/>
            <Setter Property="Background"                 Value="{DynamicResource SubBtnBg}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource AppFg}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Padding"                    Value="18,0"/>
            <Setter Property="BorderThickness"            Value="0"/>
        </Style>
        <Style Selector="StackPanel#SubMenu > Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubBtnHover}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource FgHover}"/>
        </Style>

        <!-- ToggleSwitch -->
        <Style Selector="ToggleSwitch">
            <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZн•ңл§ҲмқҢкі л”• M"/>
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeMD}"/>
        </Style>

        <!-- ScrollBar -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="30,*" Background="{DynamicResource AppBg}">

        <!-- в•җв•җв•җ мғҒлӢЁ л©”лүҙл°” в•җв•җв•җ -->
        <Border Grid.Row="0" Background="{DynamicResource MenuBarBg}" Padding="1">
            <Grid ColumnDefinitions="Auto,Auto,*">

                <!-- м ңмқј мҷјмӘҪ: м§Ғмӣҗ н”„лЎңн•„ (мӮ¬м§„ + мқҙлҰ„) -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center"
                            Margin="8,0,4,0"
                            Cursor="Hand" PointerPressed="ProfileName_Click">
                    <Border x:Name="profilePhotoBorder"
                            Width="22" Height="22" CornerRadius="11"
                            ClipToBounds="True"
                            Background="#555566"
                            VerticalAlignment="Center">
                        <Image x:Name="profilePhoto"
                               Stretch="UniformToFill"
                               IsVisible="False"/>
                    </Border>
                    <TextBlock x:Name="profileName"
                               Text="..."
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppFg}"
                               Cursor="Hand"/>
                </StackPanel>

                <!-- л©”лүҙ -->
                <Menu Grid.Column="1" HorizontalAlignment="Left"
                      Background="Transparent" VerticalAlignment="Center">

                    <MenuItem Header="мҲҳм§Ҳл¶„м„қм„јн„°">
                        <MenuItem Header="м§Ғмӣҗм •ліҙ"    Click="Agent_Click"/>
                        <MenuItem Header="кі„м•Ҫм—…мІҙ"    Click="Contract_Click"/>
                        <MenuItem Header="кІ¬м Ғ/мқҳлў°м„ң" Click="Quotation_Click"/>
                        <MenuItem Header="мӢңн—ҳм„ұм Ғм„ң"  Click="TestReport_Click"/>
                        <MenuItem Header="DB Migration" Click="DbMigration_Click"/>
                    </MenuItem>

                    <MenuItem Header="л№„мҡ©л¶ҖлӢҙкёҲ кҙҖлҰ¬">
                        <MenuItem Header="нҸҗмҲҳл°°м¶ңм—…мҶҢ"  Click="WasteCompany_Click"/>
                        <MenuItem Header="мһҗлЈҢ мЎ°нҡҢ"     Click="WasteDataQuery_Click"/>
                        <MenuItem Header="л¶„м„қмқҳлў°лҰ¬мҠӨнҠё" Click="WasteSampleList_Click"/>
                        <MenuItem Header="л¶„м„қкІ°кіјмһ…л Ҙ"/>
                        <MenuItem Header="Uipath ERP"/>
                        <MenuItem Header="мӢңн—ҳкё°лЎқл¶Җ"/>
                        <MenuItem Header="мһҗлЈҢкІҖнҶ "/>
                        <MenuItem Header="н…ҢмҠӨнҠё"/>
                    </MenuItem>

                    <MenuItem Header="мІҳлҰ¬мӢңм„Ө">
                        <MenuItem Header="мӢңн—ҳкё°лЎқл¶Җ" Click="Agent_Click"/>
                        <MenuItem Header="RDP for Zero4"/>
                    </MenuItem>

                    <MenuItem Header="мқјл°ҳм—…л¬ҙкҙҖлҰ¬" Click="Admin_Click">
                        <MenuItem Header="ліҙмҲҳмҡ”мІӯ"    Click="Repair_Click"/>
                        <MenuItem Header="л¬јн’Ҳкө¬л§Ө"    Click="Purchase_Click"/>
                        <MenuItem Header="кі„м•Ҫм—…мІҙ мұ„мҲҳ"/>
                        <MenuItem Header="м¶ңмһҘкҙҖлҰ¬"/>
                        <MenuItem Header="нңҙмқјк·јл¬ҙ"/>
                    </MenuItem>

                    <MenuItem Header="к¶Ңн•ңкҙҖлҰ¬" x:Name="PermissionMenu">
                        <MenuItem Header="м„јн„°лӘ…м№ӯ"         Click="WaterQualityNameReconcile_Click"/>
                        <MenuItem Header="нҸҗмҲҳл°°м¶ңм—…мҶҢлӘ…м№ӯ"  Click="WasteNameReconcile_Click"/>
                    </MenuItem>
                </Menu>

                <!-- мҳӨлҘёмӘҪ: кёҖмһҗ нҒ¬кё° мҠ¬лқјмқҙлҚ” + н…Ңл§Ҳ нҶ кёҖ -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="4"
                            Margin="0,0,12,0">

                    <!-- кёҖмһҗ нҒ¬кё° мҠ¬лқјмқҙлҚ” (мЈјліҖ мҡ”мҶҢ кі м • нҸӯ вҶ’ мҠ¬лқјмқҙлҚ” мң„м№ҳ кі м •) -->
                    <TextBlock Text="к°Җ"
                               FontSize="{DynamicResource FontSizeXS}"
                               Width="14" TextAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource FgMuted}"/>
                    <Slider x:Name="sldFontSize"
                            Minimum="0.9" Maximum="1.1" Value="1.0"
                            SmallChange="0.01" LargeChange="0.05"
                            TickFrequency="0.01" IsSnapToTickEnabled="True"
                            Width="100" Height="18"
                            VerticalAlignment="Center"
                            ValueChanged="SldFontSize_ValueChanged"/>
                    <TextBlock Text="к°Җ"
                               FontSize="{DynamicResource FontSizeLG}"
                               Width="18" TextAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource FgMuted}"/>
                    <TextBlock x:Name="txbFontScale"
                               Text="100%"
                               FontSize="{DynamicResource FontSizeXS}"
                               Width="30"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource FgMuted}"
                               Margin="0,0,6,0"/>

                    <!-- кө¬л¶„м„  -->
                    <Border Width="1" Height="14"
                            Background="{DynamicResource FgMuted}"
                            Opacity="0.35"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"/>

                    <!-- н…Ңл§Ҳ нҶ кёҖ -->
                    <ToggleSwitch x:Name="tglShowPassword"
                                  Margin="0,-5,0,0"
                                  VerticalAlignment="Center"
                                  OnContent="рҹҢҷ лӢӨнҒ¬ н…ңн”Ңлҹ¬"
                                  OffContent="вҳҖпёҸ н•ҳмқҙ н…ңн”Ңлҹ¬"
                                  IsChecked="True"
                                  IsCheckedChanged="OnShowPasswordChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- в•җв•җв•җ ліёл¬ё мҳҒм—ӯ в•җв•җв•җ -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- м„ңлёҢл©”лүҙ нҲҙл°” -->
            <StackPanel x:Name="SubMenu"
                        Grid.Row="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8" Margin="12,10,0,0">
                <ComboBox x:Name="cmbCategory"/>
                <Button x:Name="BT1" Content="н•ӯлӘ©1" Click="BT1_Click"/>
                <Button x:Name="BT2" Content="н•ӯлӘ©2" Click="BT2_Click"/>
                <Button x:Name="BT3" Content="н•ӯлӘ©3" Click="BT3_Click"/>
                <Button x:Name="BT4" Content="н•ӯлӘ©4" Click="BT4_Click"/>
                <Button x:Name="BT5" Content="н•ӯлӘ©5" Click="BT5_Click"/>
                <Button x:Name="BT6" Content="н•ӯлӘ©6" Click="BT6_Click"/>
                <Button x:Name="BT7" Content="н•ӯлӘ©7" Click="BT7_Click"/>
                <Button x:Name="BT8" Content="н•ӯлӘ©8" Click="BT8_Click"/>
                <Button x:Name="BT1110"/>
            </StackPanel>

            <!-- в”Җв”Җ 4л¶„н•  л Ҳмқҙм•„мӣғ в”Җв”Җ -->
            <!--
            в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
            в”Ӯ          в”Ӯ   Content2          в”Ӯ   Content4     в”Ӯ
            в”Ӯ Content1 в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
            в”Ӯ          в”Ӯ            Content3                  в”Ӯ
            в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
            к°Ғ нҢЁл„җмқҳ л„Ҳл№„/лҶ’мқҙлҠ” мҪ”л“ңм—җм„ң SetContentLayout() нҳём¶ңлЎң мЎ°м •
            -->
            <Grid Grid.Row="1" x:Name="MainSplitGrid"
                  Margin="10,10,10,10"
                  ColumnDefinitions="200,8,*">

                <!-- в”Җв”Җ Content1: мҷјмӘҪ мӮ¬мқҙл“ңл°” в”Җв”Җ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource PanelBg}"
                        CornerRadius="6" Padding="16" Margin="0,0,1,0">
                    <ContentControl x:Name="Show1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"/>
                </Border>

                <!-- мўҢмҡ° мҠӨн”ҢлҰ¬н„° -->
                <GridSplitter Grid.Column="1" Width="8"
                              Background="Transparent"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              Cursor="SizeWestEast"/>
                <Border Grid.Column="1" Width="1"
                        Background="{DynamicResource SplitterColor}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch" Opacity="0.9"/>

                <!-- в”Җв”Җ мҳӨлҘёмӘҪ (мғҒн•ҳ л¶„н• ) в”Җв”Җ -->
                <Grid Grid.Column="2" x:Name="RightSplitGrid"
                      Margin="1,0,0,0"
                      RowDefinitions="808*,8,192*">

                    <!-- мғҒлӢЁ: Content2 + Content4 (мўҢмҡ° л¶„н• ) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBg}"
                            CornerRadius="6" Padding="12">
                        <Grid x:Name="UpperContentGrid"
                              ColumnDefinitions="*,8,*">

                            <!-- Content2 -->
                            <Border Grid.Column="0"
                                    Background="{DynamicResource PanelInnerBg}"
                                    CornerRadius="4" Padding="8" Margin="0,0,4,0">
                                <ContentControl x:Name="Show2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"/>
                            </Border>

                            <!-- Content2вҶ”4 мҠӨн”ҢлҰ¬н„° -->
                            <GridSplitter x:Name="HorizontalSplitter"
                                          Grid.Column="1" Width="8"
                                          Background="Transparent"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ResizeDirection="Columns"
                                          Cursor="SizeWestEast"/>
                            <Border Grid.Column="1" Width="3"
                                    Background="{DynamicResource SplitterColor}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Margin="0,8,0,8"/>

                            <!-- Content4 -->
                            <Border x:Name="Content4Border"
                                    Grid.Column="2"
                                    Background="{DynamicResource PanelInnerBg}"
                                    CornerRadius="4" Padding="8" Margin="4,0,0,0">
                                <ContentControl x:Name="Show4"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- мғҒн•ҳ мҠӨн”ҢлҰ¬н„° -->
                    <GridSplitter x:Name="VerticalSplitter"
                                  Grid.Row="1" Height="8"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  Cursor="SizeNorthSouth"/>
                    <Border Grid.Row="1" Height="1"
                            Background="{DynamicResource SplitterColor}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center" Opacity="0.9"/>

                    <!-- н•ҳлӢЁ: Content3 (м№ҙн…Ңкі лҰ¬лі„ лҸ…лҰҪ мҠӨнҒ¬лЎӨ м„№м…ҳ) -->
                    <Border x:Name="LowerBorder"
                            Grid.Row="2"
                            Background="{DynamicResource PanelBg}"
                            CornerRadius="6" Padding="12">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ContentControl x:Name="Show3"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
