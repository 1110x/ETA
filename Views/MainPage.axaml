<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lottie="using:Avalonia.Labs.Lottie"
        x:Class="ETA.Views.MainPage"
        TransparencyLevelHint="AcrylicBlur"
        Width="1600"
        Height="900"
        Icon="avares://ETA/Assets/icons/ETA.ico"
        Title="ETA Water Analysis Center">

    <Grid RowDefinitions="30,*">
        <!-- 상단 메인 메뉴 바 -->
        <Border Grid.Row="0" Background="#444444" Padding="1">
            <Grid ColumnDefinitions="Auto,*">

                <!-- 왼쪽 메뉴 (MenuItem) -->
                <Menu Grid.Column="0" HorizontalAlignment="Left" Background="Transparent" VerticalAlignment="Center">
                    <Menu.Styles>
                        <!-- 메인 메뉴 스타일 -->
                        <Style Selector="MenuItem">
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                            <Setter Property="Height" Value="25" />
                            <Setter Property="Padding" Value="18,0" />
                            <Setter Property="Background" Value="#444444" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Style>
                        <Style Selector="MenuItem:pointerover">
                            <Setter Property="Background" Value="#012800" />
                            <!--Setter Property="Foreground" Value="#694e8c" /-->
                        </Style>

                        <!-- 서브메뉴 창 전체 -->
                        <Style Selector="MenuFlyoutPresenter">
                            <Setter Property="Background" Value="#012800" />
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="Padding" Value="5,5" />           <!-- 창 전체 여백 증가 -->
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Style>

                        <!-- 서브메뉴 항목 (글자 위아래 간격 크게 증가!) -->
                        <Style Selector="MenuItem MenuItem">
                            <Setter Property="Background" Value="#444444" />
                            <Setter Property="Padding" Value="5,5" />          <!-- ← 여기서 위아래 간격 크게! -->
                            <Setter Property="MinHeight" Value="36" />
                        </Style>

                        <!-- 글자 색 강제 적용 -->
                        <Style Selector="MenuFlyoutPresenter TextBlock">
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Style>
                        <Style Selector="MenuItem MenuItem TextBlock">
                            <Setter Property="Foreground" Value="#ffffff" />
                        </Style>
                        <Style Selector="MenuItem MenuItem:pointerover TextBlock">
                            <Setter Property="Foreground" Value="#fd0f0f" />
                        </Style>
                    </Menu.Styles>
                    <MenuItem Header="수질분석센터">
                        <MenuItem Header="직원정보" Click="Agent_Click"/>
                        <MenuItem Header="계약업체" Click="Contract_Click" />
                        <MenuItem Header="견적/의뢰서" Click="Quotation_Click"/>
                        <MenuItem Header="시험성적서" Click="TestReport_Click" />
                        <MenuItem Header="측정인" />
                        <MenuItem Header="보수요청" Click="Repair_Click" />
                        <MenuItem Header="물품구매" Click="Purchase_Click" />
                        <MenuItem Header="테스트" />
                    </MenuItem>

                    <MenuItem Header="비용부담금 관리" >
                        <MenuItem Header="폐수배출업소" Click="WasteCompany_Click" />
                        <MenuItem Header="분석의뢰리스트" />
                        <MenuItem Header="분석결과입력" />
                        <MenuItem Header="Uipath ERP" />
                        <MenuItem Header="시험기록부" />
                        <MenuItem Header="자료검토" />
                        <MenuItem Header="테스트" />
                    </MenuItem>

                    <MenuItem Header="처리시설" >
                        <MenuItem Header="시험기록부" Click="Agent_Click" />
                        <MenuItem Header="RDP for Zero4"/>
                    </MenuItem>

                    <MenuItem Header="일반업무관리" Click="Admin_Click">
                        <MenuItem Header="계약업체 채수" />
                        <MenuItem Header="출장관리" />
                        <MenuItem Header="휴일근무" />
                        <MenuItem Header="휴일근무" />
                    </MenuItem>
                </Menu>

                <!-- 오른쪽 ToggleSwitch -->
                <ToggleSwitch Grid.Column="1"
                              x:Name="tglShowPassword"
                              HorizontalAlignment="Right"
                              Margin="0,-5,20,0"
                              IsCheckedChanged="OnShowPasswordChanged"
                              VerticalAlignment="Center"
                              OnContent="🌙 다크 템플러"
                              OffContent="☀️ 하이 템플러"
                              IsChecked="True"/>
            </Grid>
        </Border>

        <!-- Inner Grid (기존 그대로) -->
        <Grid Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}" RowDefinitions="Auto, *">
            <!-- SubMenu -->
            <StackPanel x:Name="SubMenu" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8" Margin="12,10,0,0">
                <StackPanel.Styles>
                    <Style Selector="Button">
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                        <Setter Property="Height" Value="25" />
                        <Setter Property="CornerRadius" Value="4" />
                        <Setter Property="Background" Value="#342f2f" />
                        <Setter Property="Foreground" Value="#ffffff" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="18,0" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#012800" />
                    </Style>
                    <Style Selector="Button:pointerover TextBlock">
                        <Setter Property="Foreground" Value="#fd0f0f" />
                    </Style>
                </StackPanel.Styles>
                <ComboBox x:Name="cmbCategory" />
                <Button x:Name="BT1" Content="항목1" Click="BT1_Click" />
                <Button x:Name="BT2" Content="항목2" Click="BT2_Click" />
                <Button x:Name="BT3" Content="항목3" Click="BT3_Click" />
                <Button x:Name="BT4" Content="항목4" Click="BT4_Click" />
                <Button x:Name="BT5" Content="항목5" Click="BT5_Click" />
                <Button x:Name="BT6" Content="항목6" Click="BT6_Click" />
                <Button x:Name="BT7" Content="항목7" Click="BT7_Click" />
                <Button x:Name="BT1110"/>
            </StackPanel>

            <!-- 좌우 분할 + 오른쪽 상하 분할 -->
            <Grid Grid.Row="1" Margin="10,10,10,10" x:Name="MainSplitGrid" ColumnDefinitions="200,8,*">

                <!-- 왼쪽 사이드바 -->
                <Border Grid.Column="0" Background="#39383f" CornerRadius="6" Padding="16" Margin="0,0,1,0">
                    <ContentControl x:Name="ActivePageContent1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />




                </Border>

                <!-- splitter (좌우) -->
                <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns" Cursor="SizeWestEast" />

                <!-- 세로 구분선 -->
                <Border Grid.Column="1" Width="1" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Stretch" Opacity="0.9" />

                <!-- 오른쪽 영역 (상하 분할) -->
                <Grid Grid.Column="2" Margin="1,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="808*" />    <!-- ≈80.8% -->
                        <RowDefinition Height="8" />       <!-- splitter -->
                        <RowDefinition Height="192*" />    <!-- ≈19.2% -->
                    </Grid.RowDefinitions>

                    <!-- 상단 영역 (Content2 + Content4 좌우 분할) -->
                    <Border Grid.Row="0" Background="#39383f" CornerRadius="6" Padding="12">
                        <Grid ColumnDefinitions="*, 8, *">

                            <!-- 왼쪽: ActivePageContent2 -->
                            <Border Grid.Column="0"
                                    Background="#2d2d35"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,0,4,0">
                                <ContentControl x:Name="ActivePageContent2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch" />
                            </Border>

                            <!-- splitter + 구분선 (con1과 동일 구조) -->
                            <GridSplitter Grid.Column="1"
                                          Width="8"
                                          Background="Transparent"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ResizeDirection="Columns"
                                          Cursor="SizeWestEast" />

                            <Border Grid.Column="1"
                                    Width="3"
                                    Background="#020202"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Margin="0,8,0,8" />

                            <!-- 오른쪽: ActivePageContent4 -->
                            <Border Grid.Column="2"
                                    Background="#2d2d35"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="4,0,0,0">
                                <ContentControl x:Name="ActivePageContent4"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch" />
                            </Border>

                        </Grid>
                    </Border>

                    <!-- 상하 splitter -->
                    <GridSplitter Grid.Row="1"
                                  Height="8"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  Cursor="SizeNorthSouth" />

                    <!-- splitter 구분선 (일관된 색상으로) -->
                    <Border Grid.Row="1"
                            Height="1"
                            Background="#020202"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Opacity="0.9" />

                    <!-- 하단 메인 콘텐츠 영역 -->
                    <Border Grid.Row="2" Background="#39383f" CornerRadius="6" Padding="12">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ContentControl x:Name="ActivePageContent3"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>


</Window>