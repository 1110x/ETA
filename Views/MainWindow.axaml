<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ETA.ViewModels"
        xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.TreeDataGrid"
        x:Class="ETA.Views.MainWindow"
        Width="1200" Height="700"
        x:CompileBindings="False"
        Title="ETA">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="400,*">
        
        <!-- 좌측 TreeDataGrid -->
        <controls:TreeDataGrid x:Name="treeGrid"/>

        <!-- 우측 결과 DataGrid -->
        <DataGrid Grid.Column="1"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="True"/>

    </Grid>
</Window>