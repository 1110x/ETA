<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ETA.Views.MainWindow"
        Title="ETA" Width="1500" Height="900">

    <Grid ColumnDefinitions="230,*,200"
          RowDefinitions="*,40,20">
        <TreeView x:Name="Tree"
                  Grid.Column="0"
                  Margin="5"/>
        
        <ListBox x:Name="SelectedList"
                 Grid.Column="1"
                 Margin="10"/>
        
        <ListBox x:Name="PriceList"
                 Grid.Column="2"
                 Margin="10"/>
        
        <Button Grid.Column="2"
                Grid.Row="1"
                Content="To Do 생성"
                Width="120"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="BtnCreateTodo_Click"/>
        
        <TextBlock x:Name="TotalPriceText"
                   Grid.Row="2"
                   Grid.ColumnSpan="3"
                   FontSize="24"
                   HorizontalAlignment="Right"
                   Margin="20"
                   Text="Total : 0"/>
    </Grid>
</Window>