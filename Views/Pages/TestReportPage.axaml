<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.TestReportPage">

    <UserControl.Styles>
        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a4a1a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#252535" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 정렬 토글 -->
        <Border Grid.Row="0" Background="#2a2a3a" Padding="6,2">
            <ToggleSwitch x:Name="tglSortMode"
                          IsChecked="False"
                          IsCheckedChanged="SortToggle_Changed"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          OnContent="📅 날짜별 보기"
                          OffContent="🏭 업체별 보기" />
        </Border>

        <!-- 트리뷰 -->
        <TreeView Grid.Row="1"
                  x:Name="ReportTreeView"
                  Margin="0,2,0,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="ReportTreeView_SelectionChanged" />

    </Grid>

</UserControl>
