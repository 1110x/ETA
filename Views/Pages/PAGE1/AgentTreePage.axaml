<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE1.AgentTreePage">

    <UserControl.Styles>
        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="10,6">
            <TextBlock Text="\uc9c1\uc6d0 \ubaa9\ub85d"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgMuted}"
                       FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                       VerticalAlignment="Center"/>
        </Border>
        <TextBox Grid.Row="1"
                 x:Name="AgentSearchBox"
                 Watermark="🔍 직원 검색..."
                 FontSize="{DynamicResource FontSizeMD}"
                 FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                 Height="32" Margin="5,4,5,2"
                 CornerRadius="6" Padding="8,5"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource InputBorder}"
                 Background="{DynamicResource PanelBg}"
                 TextChanged="AgentSearchBox_TextChanged"/>
        <ComboBox Grid.Row="2"
                  x:Name="DeptFilterBox"
                  FontSize="{DynamicResource FontSizeMD}"
                  FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                  Height="30" Margin="5,0,5,3"
                  Padding="8,4"
                  HorizontalAlignment="Stretch"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource InputBorder}"
                  Background="{DynamicResource PanelBg}"
                  SelectionChanged="DeptFilter_SelectionChanged"/>
        <TreeView Grid.Row="3"
                  x:Name="AgentTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="AgentTreeView_SelectionChanged" />
    </Grid>

</UserControl>
