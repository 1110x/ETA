<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:ETA.Models"
             x:Class="ETA.Views.Pages.PAGE1.DbMigrationPage">

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding"      Value="8,4" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{DynamicResource AppFg}" />
            <Setter Property="FontSize"     Value="{DynamicResource FontSizeMD}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="FontFamily"   Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeSelBg}" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeHoverBg}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   x:Name="txbPanelTitle"
                   Text="ETA 계약 DB 업체"
                   FontSize="{DynamicResource FontSizeMD}" FontWeight="Bold"
                   Foreground="{DynamicResource AppFg}"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                   Margin="0,0,0,6"/>

        <!-- 토글: 활성계약만 / 전체 -->
        <ToggleSwitch Grid.Row="1"
                      x:Name="tglActiveOnly"
                      IsChecked="True"
                      OnContent="✅ 활성계약만"
                      OffContent="📋 전체 업체"
                      FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                      FontSize="{DynamicResource FontSizeBase}"
                      HorizontalAlignment="Left"
                      Margin="8,2,0,6"
                      IsCheckedChanged="TglActiveOnly_Changed" />

        <!-- 검색 -->
        <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,6">
            <TextBox x:Name="txbSearch"
                     Watermark="업체명 / 약칭 검색..."
                     Height="26" FontSize="{DynamicResource FontSizeBase}"
                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                     BorderBrush="{DynamicResource InputBorder}" Padding="8,0" CornerRadius="4"
                     FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                     TextChanged="TxbSearch_TextChanged" />
            <TextBlock x:Name="txbCount"
                       Text="0개 업체"
                       FontSize="{DynamicResource FontSizeBase}" Foreground="{DynamicResource FgMuted}"
                       Margin="2,0,0,0"
                       FontFamily="avares://ETA/Assets/Fonts#Pretendard" />
        </StackPanel>

        <!-- 선택된 업체 표시 -->
        <TextBlock Grid.Row="3"
                   x:Name="txbSelected"
                   Text=""
                   FontSize="{DynamicResource FontSizeBase}" Foreground="{DynamicResource ThemeFgInfo}"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                   Margin="2,0,0,4"
                   IsVisible="False"/>

        <!-- 업체 목록 -->
        <ListBox Grid.Row="4"
                 x:Name="lbxCompanies"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="LbxCompanies_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="models:Contract">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                          ToolTip.Tip="{Binding C_ContractEndStr}">
                        <!-- 업체명 -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding C_CompanyName}"
                                   FontSize="{DynamicResource FontSizeBase}"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <!-- 약칭 배지 -->
                        <Border Grid.Column="1"
                                Background="{Binding BadgeBg}" CornerRadius="3"
                                Padding="4,1" Margin="4,0,0,0"
                                IsVisible="{Binding HasAbbr}">
                            <TextBlock Text="{Binding C_Abbreviation}"
                                       FontSize="{DynamicResource FontSizeSM}" Foreground="{Binding BadgeFg}" />
                        </Border>
                        <!-- 잔여계약일 배지 -->
                        <Border Grid.Column="3"
                                Background="{Binding DaysLeftBg}" CornerRadius="3"
                                Padding="4,1" Margin="4,0,0,0"
                                IsVisible="{Binding HasDaysLeft}">
                            <TextBlock Text="{Binding DaysLeftText}"
                                       FontSize="{DynamicResource FontSizeSM}" Foreground="{Binding DaysLeftFg}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
