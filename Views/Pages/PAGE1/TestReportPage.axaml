<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE1.TestReportPage">

    <UserControl.Styles>
        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 정렬 토글 헤더 + 검색창 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,*">
                <ToggleSwitch Grid.Column="0"
                              x:Name="tglSortMode"
                              IsChecked="True"
                              IsCheckedChanged="SortToggle_Changed"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              OnContent="📅 날짜별 보기"
                              OffContent="🏭 업체별 보기"/>
                <TextBox Grid.Column="1"
                         x:Name="txbSearch"
                         Watermark="🔍 검색..."
                         Height="22" FontSize="{DynamicResource FontSizeBase}"
                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                         BorderBrush="{DynamicResource InputBorder}" Padding="6,0" CornerRadius="4"
                         Margin="6,0,0,0"
                         VerticalAlignment="Center"
                         FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R"
                         TextChanged="TxbSearch_TextChanged"/>
            </Grid>
        </Border>

        <!-- 트리뷰 영역 -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelInnerBg}"
                CornerRadius="0,0,6,6"
                Padding="2,2">
            <TreeView x:Name="ReportTreeView"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      SelectionChanged="ReportTreeView_SelectionChanged" />
        </Border>

    </Grid>

</UserControl>
