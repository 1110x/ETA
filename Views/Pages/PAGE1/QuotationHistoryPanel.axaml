<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE1.QuotationHistoryPanel">

    <UserControl.Styles>
        <Style Selector="Button.ghost-btn">
            <Setter Property="Height"          Value="22" />
            <Setter Property="CornerRadius"    Value="3" />
            <Setter Property="Background"      Value="#2a2a3a" />
            <Setter Property="Foreground"      Value="#aaa" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>
        <Style Selector="Button.ghost-btn:pointerover">
            <Setter Property="Background" Value="#3a3a4a" />
        </Style>
        <Style Selector="Button.danger-btn">
            <Setter Property="Height"          Value="22" />
            <Setter Property="CornerRadius"    Value="3" />
            <Setter Property="Background"      Value="#4a2a2a" />
            <Setter Property="Foreground"      Value="#f0aeae" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>

        <!-- ToggleSwitch 글꼴 -->
        <Style Selector="ToggleSwitch">
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Foreground" Value="#cccccc" />
        </Style>

        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a4a1a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#252535" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- ① 헤더 영역: ToggleSwitch + 검색창 + 툴바 -->
        <Border Grid.Row="0"
                Background="#1a1a28"
                CornerRadius="6,6,0,0"
                Padding="8,4"
                Margin="0,0,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

                <!-- 토글 스위치: Off=견적발행내역 / On=분석의뢰내역 -->
                <ToggleSwitch Grid.Column="0"
                              x:Name="tglTab"
                              IsChecked="False"
                              OffContent="견적발행내역"
                              OnContent="분석의뢰내역"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              IsCheckedChanged="TglTab_Changed" />

                <!-- 검색창 -->
                <TextBox Grid.Column="1"
                         x:Name="txbSearch"
                         Watermark="🔍 검색..."
                         Height="22" FontSize="{DynamicResource FontSizeBase}"
                         Background="#252535" Foreground="#ddd"
                         BorderBrush="#444" Padding="6,0" CornerRadius="4"
                         Margin="6,0,6,0"
                         VerticalAlignment="Center"
                         FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R"
                         TextChanged="TxbSearch_TextChanged" />

                <!-- 탭 레이블 (현재 탭 이름) -->
                <TextBlock Grid.Column="2"
                           x:Name="txbTabLabel"
                           Text=""
                           FontSize="{DynamicResource FontSizeSM}" Foreground="#556677"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />

                <Button Grid.Column="3"
                        Classes="danger-btn"
                        Content="🗑 삭제"
                        Margin="0,0,4,0"
                        Click="BtnDelete_Click" />
                <Button Grid.Column="4"
                        Classes="ghost-btn"
                        Content="🔄"
                        Width="26" Padding="0"
                        Click="BtnRefresh_Click" />
            </Grid>
        </Border>

        <!-- ② 구분선 -->
        <Border Grid.Row="1" Height="1" Background="#333" Margin="0,0,0,2" />

        <!-- ③ AXAML tvHistory (더미, 핸들러 연결용) -->
        <TreeView Grid.Row="2"
                  x:Name="tvHistory"
                  IsVisible="False"
                  SelectionChanged="TvHistory_SelectionChanged" />

        <!-- ④ treeHost -->
        <Border Grid.Row="3"
                Background="#13131f"
                CornerRadius="0,0,6,6"
                Padding="2,2">
            <Grid x:Name="treeHost" Background="Transparent" />
        </Border>

        <!-- ⑤ 하단 정보 -->
        <TextBlock Grid.Row="4"
                   x:Name="txbInfo"
                   Text=""
                   FontSize="{DynamicResource FontSizeSM}" Foreground="#556677"
                   Margin="2,3,0,0"
                   FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</UserControl>
