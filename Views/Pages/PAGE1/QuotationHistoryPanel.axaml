<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE1.QuotationHistoryPanel">

    <UserControl.Styles>
        <Style Selector="Button.ghost-btn">
            <Setter Property="Height"          Value="22" />
            <Setter Property="CornerRadius"    Value="3" />
            <Setter Property="Background"      Value="{DynamicResource SubBtnBg}" />
            <Setter Property="Foreground"      Value="{DynamicResource FgMuted}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>
        <Style Selector="Button.ghost-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TreeHoverBg}" />
        </Style>
        <Style Selector="Button.danger-btn">
            <Setter Property="Height"          Value="22" />
            <Setter Property="CornerRadius"    Value="3" />
            <Setter Property="Background"      Value="#4a2a2a" />
            <Setter Property="Foreground"      Value="#f0aeae" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>

        <!-- ToggleSwitch 글꼴 -->
        <Style Selector="ToggleSwitch">
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
        </Style>

        <!-- 탭 버튼 -->
        <Style Selector="Button.tab-btn">
            <Setter Property="Height"          Value="24" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Background"      Value="{DynamicResource SubBtnBg}" />
            <Setter Property="Foreground"      Value="{DynamicResource FgMuted}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>
        <Style Selector="Button.tab-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TreeHoverBg}" />
        </Style>
        <Style Selector="Button.tab-btn.active">
            <Setter Property="Background" Value="{DynamicResource TreeSelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource AppFg}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"       Value="1,0" />
            <Setter Property="Margin"        Value="0" />
            <Setter Property="MinHeight"     Value="0" />
            <Setter Property="FontSize"      Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground"    Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily"    Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Background"    Value="Transparent" />
            <Setter Property="ClipToBounds"  Value="False" />
        </Style>
        <!-- 리프 노드: expander(▶) 토글버튼 공간 제거 -->
        <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
            <Setter Property="Width"      Value="12" />
            <Setter Property="MinWidth"   Value="0" />
            <Setter Property="Padding"    Value="0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="Opacity"    Value="0" />
        </Style>
        <!-- 부모 노드: expander 원래대로 -->
        <Style Selector="TreeViewItem:hasitems /template/ ToggleButton#PART_ExpandCollapseChevron">
            <Setter Property="Width"      Value="19" />
            <Setter Property="MinWidth"   Value="19" />
            <Setter Property="Opacity"    Value="1" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- ① 헤더 영역: ToggleSwitch + 검색창 + 툴바 -->
        <Border Grid.Row="0"
                x:Name="headerBorder"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="8,4"
                Margin="0,0,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">

                <!-- 탭 버튼: 견적발행내역 / 분석의뢰내역 / 거래명세발행내역 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button x:Name="btnTabQuotation"
                            Classes="tab-btn active"
                            Content="견적발행내역"
                            Click="BtnTabQuotation_Click" />
                    <Button x:Name="btnTabAnalysis"
                            Classes="tab-btn"
                            Content="분석의뢰내역"
                            Click="BtnTabAnalysis_Click" />
                    <Button x:Name="btnTabStatement"
                            Classes="tab-btn"
                            Content="거래명세발행내역"
                            Click="BtnTabStatement_Click" />
                </StackPanel>

                <!-- 검색창 -->
                <TextBox Grid.Column="1"
                         x:Name="txbSearch"
                         Watermark="🔍 검색..."
                         Height="22" FontSize="{DynamicResource FontSizeBase}"
                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                         BorderBrush="{DynamicResource InputBorder}" Padding="6,0" CornerRadius="4"
                         Margin="6,0,6,0"
                         VerticalAlignment="Center"
                         FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                         TextChanged="TxbSearch_TextChanged" />

                <!-- 탭 레이블 (현재 탭 이름) -->
                <TextBlock Grid.Column="2"
                           x:Name="txbTabLabel"
                           Text=""
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard" />

                <Button Grid.Column="3"
                        Classes="danger-btn"
                        Content="🗑 삭제"
                        Margin="0,0,4,0"
                        Click="BtnDelete_Click" />
                <Button Grid.Column="4"
                        Classes="ghost-btn"
                        Content="🔄"
                        Width="26" Padding="0"
                        Click="BtnRefresh_Click" />
            </Grid>
        </Border>

        <!-- ② 구분선 -->
        <Border Grid.Row="1" x:Name="separatorBorder" Height="1" Background="{DynamicResource ThemeBorderSeparator}" Margin="0,0,0,2" />

        <!-- ③ AXAML tvHistory (더미, 핸들러 연결용) -->
        <TreeView Grid.Row="2"
                  x:Name="tvHistory"
                  IsVisible="False"
                  SelectionChanged="TvHistory_SelectionChanged" />

        <!-- ④ treeHost -->
        <Border Grid.Row="3"
                x:Name="treeHostBorder"
                Background="{DynamicResource PanelInnerBg}"
                CornerRadius="0,0,6,6"
                Padding="2,2"
                ClipToBounds="False">
            <Grid x:Name="treeHost" Background="Transparent" ClipToBounds="False" />
        </Border>

        <!-- ⑤ 하단 정보 -->
        <TextBlock Grid.Row="4"
                   x:Name="txbInfo"
                   Text=""
                   FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                   Margin="2,3,0,0"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</UserControl>
