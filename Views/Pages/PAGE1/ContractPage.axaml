<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE1.ContractPage">

    <UserControl.Styles>
        <!-- ToggleSwitch -->
        <Style Selector="ToggleSwitch">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>
        <!-- TreeViewItem -->
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a4a1a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#252535" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Background="#1a1a28"
                CornerRadius="6,6,0,0"
                Padding="10,6">
            <TextBlock Text="계약업체 목록"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#8899bb"
                       FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                       VerticalAlignment="Center"/>
        </Border>
        <Border Grid.Row="1"
                Background="#13131f"
                Padding="8,4">
            <ToggleSwitch x:Name="tglContractStatus"
                          IsChecked="True"
                          OnContent="✅ 현행계약"
                          OffContent="📁 종료계약"
                          IsCheckedChanged="TglContractStatus_Changed" />
        </Border>
        <TreeView Grid.Row="2"
                  x:Name="ContractTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="ContractTreeView_SelectionChanged" />
    </Grid>

</UserControl>