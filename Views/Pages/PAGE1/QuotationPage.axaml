<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:ETA.Models"
             x:Class="ETA.Views.Pages.PAGE1.QuotationPage">

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding"      Value="8,4" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{DynamicResource AppFg}" />
            <Setter Property="FontSize"     Value="{DynamicResource FontSizeMD}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="FontFamily"   Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeSelBg}" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeHoverBg}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   x:Name="txbHeader"
                   Text="측정인 업체"
                   FontSize="{DynamicResource FontSizeMD}" FontWeight="Bold"
                   Foreground="{DynamicResource AppFg}"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                   Margin="0,0,0,6"/>

        <!-- ToggleSwitch (측정인 DB / 계약 DB) -->
        <ToggleSwitch Grid.Row="1"
                      x:Name="tglActiveOnly"
                      IsChecked="False"
                      OnContent="📋 계약 DB"
                      OffContent="📍 측정인 DB"
                      FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                      FontSize="{DynamicResource FontSizeBase}"
                      HorizontalAlignment="Left"
                      Margin="8,2,0,6"
                      IsCheckedChanged="TglActiveOnly_Changed" />

        <!-- 검색 + 건수 -->
        <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,6">
            <TextBox x:Name="txbSearch"
                     Watermark="업체명 검색..."
                     Height="26" FontSize="{DynamicResource FontSizeBase}"
                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                     BorderBrush="{DynamicResource InputBorder}" Padding="8,0" CornerRadius="4"
                     FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                     TextChanged="TxbSearch_TextChanged" />
            <TextBlock x:Name="txbCompanyCount"
                       Text="0개 업체"
                       FontSize="{DynamicResource FontSizeBase}" Foreground="{DynamicResource FgMuted}"
                       Margin="2,0,0,0"
                       FontFamily="avares://ETA/Assets/Fonts#Pretendard" />
        </StackPanel>

        <!-- 업체 목록 (ListBox) -->
        <ListBox Grid.Row="3"
                 x:Name="lbCompanies"
                 SelectionChanged="LbCompanies_SelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="models:Contract">
                    <Grid ColumnDefinitions="2*,*,*,*,*">
                        <TextBlock Grid.Column="0" Text="{Binding C_CompanyName}" Margin="6,2"/>
                        <TextBlock Grid.Column="1" Text="{Binding C_Abbreviation}" Margin="6,2"/>
                        <TextBlock Grid.Column="2" Text="{Binding C_ContractStartStr}" Margin="6,2"/>
                        <TextBlock Grid.Column="3" Text="{Binding C_ContractEndStr}" Margin="6,2"/>
                        <TextBlock Grid.Column="4" Text="{Binding DaysLeftText}" HorizontalAlignment="Right" Margin="6,2"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
