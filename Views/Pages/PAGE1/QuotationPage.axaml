<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:ETA.Models"
             x:Class="ETA.Views.Pages.PAGE1.QuotationPage">

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding"      Value="8,4" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{DynamicResource AppFg}" />
            <Setter Property="FontSize"     Value="{DynamicResource FontSizeMD}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="FontFamily"   Value="avares://ETA/Assets/Fonts#Pretendard" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeSelBg}" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeHoverBg}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   x:Name="txbHeader"
                   Text="측정인 업체"
                   FontSize="{DynamicResource FontSizeMD}" FontWeight="Bold"
                   Foreground="{DynamicResource AppFg}"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                   Margin="0,0,0,6"/>

        <!-- ToggleSwitch + 검색 (한 줄) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="8,2,0,6">
            <ToggleSwitch x:Name="tglActiveOnly"
                          IsChecked="True"
                          OnContent="📋 계약 DB"
                          OffContent="📍 측정인 DB"
                          FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                          FontSize="{DynamicResource FontSizeBase}"
                          HorizontalAlignment="Left"
                          IsCheckedChanged="TglActiveOnly_Changed" />
            <TextBox x:Name="txbSearch"
                     Watermark="업체명 검색..."
                     Height="26" FontSize="{DynamicResource FontSizeBase}"
                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}"
                     BorderBrush="{DynamicResource InputBorder}" Padding="8,0" CornerRadius="4"
                     FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                     Width="200"
                     TextChanged="TxbSearch_TextChanged" />
        </StackPanel>

        <!-- 건수 표시 -->
        <TextBlock Grid.Row="2"
                   x:Name="txbCompanyCount"
                   Text="0개 업체"
                   FontSize="{DynamicResource FontSizeBase}" Foreground="{DynamicResource FgMuted}"
                   Margin="8,0,0,6"
                   FontFamily="avares://ETA/Assets/Fonts#Pretendard" />

        <!-- 업체 목록 (2컬럼 그리드) -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="spCompanies" Spacing="4" Margin="4"/>
        </ScrollViewer>

    </Grid>
</UserControl>
