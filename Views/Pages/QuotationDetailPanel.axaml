<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.QuotationDetailPanel">

    <UserControl.Styles>
        <Style Selector="TextBlock.lbl">
            <Setter Property="FontSize"          Value="11" />
            <Setter Property="Foreground"        Value="#666" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily"        Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>
        <Style Selector="TextBlock.val">
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Foreground"        Value="#ddd" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily"        Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="TextWrapping"      Value="Wrap" />
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Height"          Value="26" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Background"      Value="#2a4a2a" />
            <Setter Property="Foreground"      Value="#aef0ae" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="12,0" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>
        <Style Selector="Button.danger-btn">
            <Setter Property="Height"          Value="26" />
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Background"      Value="#4a2a2a" />
            <Setter Property="Foreground"      Value="#f0aeae" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="12,0" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   Text="발행 세부내역"
                   FontSize="13" FontWeight="Bold"
                   Foreground="#e0e0e0"
                   FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                   Margin="0,0,0,6"/>

        <Border Grid.Row="1" Height="1" Background="#333" Margin="0,0,0,8" />

        <!-- 내용 -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6">

                <!-- 빈 상태 -->
                <TextBlock x:Name="txbEmpty"
                           Text="왼쪽 트리에서 발행건을 선택하세요."
                           FontSize="12"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                           Foreground="#555"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,0" />

                <!-- 실제 내용 -->
                <StackPanel x:Name="spContent" IsVisible="False" Spacing="6">

                    <!-- 기본 정보 -->
                    <Border Background="#1e2530" CornerRadius="5" Padding="12,8">
                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="lbl" Text="업체명" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Classes="val" x:Name="txbCompany" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="lbl" Text="약칭" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="val" x:Name="txbAbbr" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="lbl" Text="시료명" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="val" x:Name="txbSampleName" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Classes="lbl" Text="견적번호" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Classes="val" x:Name="txbNo" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Classes="lbl" Text="발행일" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Classes="val" x:Name="txbDate" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Classes="lbl" Text="적용구분" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Classes="val" x:Name="txbType" Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <!-- 합계 금액 -->
                    <Border Background="#1a2a1a" CornerRadius="5" Padding="12,8">
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Grid.Column="0" Classes="lbl" Text="합계 금액" />
                            <TextBlock Grid.Column="1" x:Name="txbAmount"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#7cd87c"
                                       FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
                        </Grid>
                    </Border>

                    <!-- 항목 라인 목록 (동적 생성) -->
                    <Border Background="#1e2030" CornerRadius="5" Padding="0">
                        <StackPanel>
                            <!-- 컬럼 헤더 -->
                            <Grid ColumnDefinitions="*,60,80,80"
                                  Margin="12,6,12,4">
                                <TextBlock Grid.Column="0" Classes="lbl" Text="항목" />
                                <TextBlock Grid.Column="1" Classes="lbl" Text="수량"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Classes="lbl" Text="단가"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="3" Classes="lbl" Text="소계"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#2a2a3a" Margin="8,0"/>
                            <!-- 항목 행 컨테이너 -->
                            <StackPanel x:Name="spItems" Spacing="0" Margin="0,2,0,4"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="3" x:Name="spButtons"
                    Orientation="Horizontal" Spacing="8"
                    Margin="0,6,0,0" IsVisible="False">
            <Button Classes="action-btn" Content="✏️  이 건 수정" Click="BtnEdit_Click" />
            <Button Classes="action-btn" Content="🖨  인쇄"      Click="BtnPrint_Click" />
            <Button Classes="danger-btn" Content="🗑  삭제"      Click="BtnDelete_Click" />
        </StackPanel>

    </Grid>
</UserControl>
