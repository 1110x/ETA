<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE2.ProcessingFacilityPage">

    <UserControl.Styles>
        <Style Selector="Button.FacBtn">
            <Setter Property="Height"              Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"            Value="{DynamicResource FontSizeBase}"/>
            <Setter Property="FontFamily"          Value="avares://ETA/Assets/Fonts#Pretendard"/>
            <Setter Property="Background"          Value="{DynamicResource SubBtnBg}"/>
            <Setter Property="Foreground"          Value="{DynamicResource FgMuted}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="BorderBrush"         Value="{DynamicResource InputBorder}"/>
            <Setter Property="CornerRadius"        Value="4"/>
            <Setter Property="Padding"             Value="8,0"/>
        </Style>
        <Style Selector="Button.FacBtn:pointerover">
            <Setter Property="Background" Value="#2a3a2a"/>
            <Setter Property="Foreground" Value="#88ee88"/>
        </Style>
        <Style Selector="Button.FacBtn.selected">
            <Setter Property="Background"   Value="#1a3a1a"/>
            <Setter Property="Foreground"   Value="#88ff88"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource ThemeBorderActive}"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 헤더 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="10,6">
            <TextBlock Text="처리시설 측정결과 입력"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgMuted}"
                       FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>
        </Border>

        <!-- 좌측 선택 패널 (스크롤) -->
        <ScrollViewer Grid.Row="1"
                      x:Name="svLeft"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,8,8,8" Spacing="8">

                <!-- 시설 선택 -->
                <TextBlock Text="시설 선택"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>
                <StackPanel x:Name="FacilityButtonPanel"
                            Orientation="Vertical"
                            Spacing="4"
                            HorizontalAlignment="Stretch"/>

                <!-- 채취일 -->
                <TextBlock Text="채취일"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           Margin="0,6,0,0"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>
                <CalendarDatePicker x:Name="dpDate"
                                    FontSize="{DynamicResource FontSizeBase}" Height="30"
                                    FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>

                <!-- 조회 + 파일첨부 + 생성 + 삭제 버튼 -->
                <Grid ColumnDefinitions="*,8,*,8,*,8,*">
                    <Button Grid.Column="0"
                            x:Name="btnLoad"
                            Content="조회"
                            Height="30" FontSize="{DynamicResource FontSizeBase}"
                            FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                            Background="{DynamicResource ThemeBgActiveGreen}" Foreground="{DynamicResource ThemeFgSuccess}"
                            BorderThickness="0" CornerRadius="4"
                            HorizontalAlignment="Stretch"
                            Click="BtnLoad_Click"/>
                    <Button Grid.Column="2"
                            x:Name="btnAttach"
                            Content="📂 파일"
                            Height="30" FontSize="{DynamicResource FontSizeBase}"
                            FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                            Background="{DynamicResource BtnInfoBg}" Foreground="{DynamicResource BtnInfoFg}"
                            BorderThickness="0" CornerRadius="4"
                            HorizontalAlignment="Stretch"
                            Click="BtnAttach_Click"/>
                    <Button Grid.Column="4"
                            x:Name="btnGenerateToday"
                            Content="📅 오늘 생성"
                            Height="30" FontSize="{DynamicResource FontSizeBase}"
                            FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                            Background="#5533aa" Foreground="#ddbbff"
                            BorderThickness="0" CornerRadius="4"
                            HorizontalAlignment="Stretch"
                            Click="BtnGenerateToday_Click"/>
                    <Button Grid.Column="6"
                            x:Name="btnDelete"
                            Content="🗑️ 삭제"
                            Height="30" FontSize="{DynamicResource FontSizeBase}"
                            FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                            Background="{DynamicResource ThemeBgDanger}" Foreground="{DynamicResource ThemeFgDanger}"
                            BorderThickness="0" CornerRadius="4"
                            HorizontalAlignment="Stretch"
                            Click="BtnDelete_Click"/>
                </Grid>

                <!-- 시험기록부 출력 -->
                <Button x:Name="btnTestRecordBook"
                        Content="📕 시험기록부 (선택 날짜 기준)"
                        Height="30" FontSize="{DynamicResource FontSizeBase}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Background="#3a1a2a" Foreground="#ee99cc"
                        BorderThickness="0" CornerRadius="4"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Stretch"
                        Click="BtnTestRecordBook_Click"/>

                <!-- 상태 텍스트 -->
                <TextBlock x:Name="tbStatus"
                           FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource FgMuted}"
                           TextWrapping="Wrap"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
