<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE2.WasteDataQueryPage">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="자료 조회"
                           FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="BtnYeosoo"
                        Content="🌊 여수"
                        Click="GroupTab_Click"
                        Tag="여수"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3" CornerRadius="10"
                        Background="{DynamicResource ThemeBgActiveBlue}" Foreground="{DynamicResource ThemeFgInfo}"
                        BorderThickness="1" BorderBrush="{DynamicResource ThemeBorderInfo}"/>
                <Button x:Name="BtnYulchon"
                        Content="🏗 율촌"
                        Click="GroupTab_Click"
                        Tag="율촌"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3" CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
                <Button x:Name="BtnSepung"
                        Content="🏭 세풍"
                        Click="GroupTab_Click"
                        Tag="세풍"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3" CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
            </StackPanel>
        </Border>
        <TreeView Grid.Row="1"
                  x:Name="WasteCompanyTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="WasteCompanyTreeView_SelectionChanged" />
    </Grid>

</UserControl>
