<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE2.WasteAssignmentPage">

    <UserControl.Styles>
        <Style Selector="Button.GrpBtn">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}"/>
            <Setter Property="FontFamily"      Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
            <Setter Property="Background"      Value="{DynamicResource SubBtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource FgMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>
        <Style Selector="Button.GrpBtn:pointerover">
            <Setter Property="Background" Value="#2a3a2a"/>
            <Setter Property="Foreground" Value="#88ee88"/>
        </Style>
        <Style Selector="Button.GrpBtn.selected">
            <Setter Property="Background"  Value="#1a3a1a"/>
            <Setter Property="Foreground"  Value="#88ff88"/>
            <Setter Property="BorderBrush" Value="#2a6a2a"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Height"      Value="26"/>
            <Setter Property="FontSize"    Value="{DynamicResource FontSizeBase}"/>
            <Setter Property="FontFamily"  Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- 헤더 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="10,6">
            <TextBlock Text="작업 배정 / 의뢰 등록"
                       FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgMuted}"
                       FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
        </Border>

        <!-- 좌측 컨트롤 패널 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,8,8,8" Spacing="8">

                <!-- ── 날짜 / 조회 ── -->
                <TextBlock Text="채취일자"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                <CalendarDatePicker x:Name="dpDate"
                                    FontSize="{DynamicResource FontSizeBase}" Height="30"
                                    FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                <Button x:Name="btnLoad"
                        Content="조회"
                        Height="30" FontSize="{DynamicResource FontSizeBase}"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Background="#1a3a2a" Foreground="#88ee88"
                        BorderThickness="0" CornerRadius="4"
                        Click="BtnLoad_Click"/>

                <!-- ── 구분선 ── -->
                <Border Height="1" Background="{DynamicResource InputBorder}" Margin="0,4,0,4"/>

                <!-- ── 의뢰 등록 ── -->
                <TextBlock Text="의뢰 등록"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}" FontWeight="SemiBold"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>

                <TextBlock Text="구분"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                <ComboBox x:Name="cbGroup"
                          SelectionChanged="CbGroup_SelectionChanged">
                    <ComboBoxItem Content="여수"/>
                    <ComboBoxItem Content="율촌"/>
                    <ComboBoxItem Content="세풍"/>
                </ComboBox>

                <TextBlock Text="업체"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                <ComboBox x:Name="cbCompany" PlaceholderText="구분 먼저 선택"/>

                <TextBlock Text="분석항목 (복수 선택)"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}" Margin="0,4,0,0"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                <WrapPanel Orientation="Horizontal">
                    <CheckBox x:Name="chkBOD"     Content="BOD"    FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkTOC"     Content="TOC"    FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkSS"      Content="SS"     FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkTN"      Content="T-N"    FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkTP"      Content="T-P"    FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkPhenols" Content="Phenols" FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkHexane"  Content="N-Hexane" FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                    <CheckBox x:Name="chkCOD"     Content="COD"    FontSize="{DynamicResource FontSizeSM}"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>
                </WrapPanel>

                <Button x:Name="btnCreate"
                        Content="의뢰 생성"
                        Height="28" FontSize="{DynamicResource FontSizeBase}"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Background="#1a2a3a" Foreground="#88aaee"
                        BorderThickness="0" CornerRadius="4"
                        Click="BtnCreate_Click"/>

                <!-- ── 상태 ── -->
                <TextBlock x:Name="tbStatus"
                           FontSize="{DynamicResource FontSizeSM}" Foreground="{DynamicResource FgMuted}"
                           TextWrapping="Wrap"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
