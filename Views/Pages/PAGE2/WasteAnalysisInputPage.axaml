<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE2.WasteAnalysisInputPage">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: 헤더 + 3-tab 모드 토글 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="📝 분석결과입력"
                           FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="BtnModeWaterCenter"
                        Content="🔬 수질분석센터"
                        Click="ModeTab_Click"
                        Tag="수질분석센터"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeBgActiveBlue}"
                        Foreground="{DynamicResource ThemeFgInfo}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBorderInfo}"/>
                <Button x:Name="BtnModeFacility"
                        Content="🏭 처리시설"
                        Click="ModeTab_Click"
                        Tag="처리시설"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
                <Button x:Name="BtnModeBilling"
                        Content="💰 비용부담금"
                        Click="ModeTab_Click"
                        Tag="비용부담금"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
            </StackPanel>
        </Border>

        <!-- Row 1: 분석항목 버튼 패널 -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelInnerBg}"
                Padding="6,4">
            <WrapPanel x:Name="AnalysisItemButtons"
                       Orientation="Horizontal"
                       HorizontalAlignment="Stretch" />
        </Border>

        <!-- Row 2: 로딩 프로그레스바 + 날짜 트리뷰 -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">

            <!-- 로딩 진행 표시 -->
            <Border x:Name="LoadProgressBorder"
                    Grid.Row="0"
                    IsVisible="False"
                    Background="{DynamicResource PanelInnerBg}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="LoadProgressText"
                               Text="로딩 중..."
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                               Foreground="{DynamicResource FgMuted}"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="LoadProgressBar"
                                 Minimum="0" Maximum="1" Value="0"
                                 Width="120" Height="6"
                                 IsIndeterminate="False" />
                </StackPanel>
            </Border>

            <TreeView Grid.Row="1"
                      x:Name="DateTreeView"
                      Margin="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      SelectionChanged="DateTreeView_SelectionChanged" />
        </Grid>

    </Grid>
</UserControl>
