<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE2.WasteSampleListPage">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Row 0: 헤더 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="10,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="채수 의뢰 목록"
                           FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                           VerticalAlignment="Center"/>
                <Button x:Name="btnNewDate"
                        Content="+ 날짜 추가"
                        Height="20" FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Background="#1a3a2a" Foreground="#88ee88"
                        BorderThickness="0" CornerRadius="3"
                        Padding="8,0"
                        Click="BtnNewDate_Click"/>
            </StackPanel>
        </Border>

        <!-- Row 1: 인라인 캘린더 (토글) -->
        <Border Grid.Row="1"
                x:Name="CalendarPickerBorder"
                IsVisible="False"
                Background="{DynamicResource PanelInnerBg}"
                BorderBrush="{DynamicResource InputBorder}"
                BorderThickness="0,0,0,1"
                Padding="4,4">
            <Calendar x:Name="InlineCalendar"
                      SelectionMode="SingleDate"
                      FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                      FontSize="{DynamicResource FontSizeMD}"
                      SelectedDatesChanged="InlineCalendar_DateChanged" />
        </Border>

        <!-- Row 2: 날짜 트리뷰 -->
        <TreeView Grid.Row="2"
                  x:Name="DateTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="DateTreeView_SelectionChanged" />

    </Grid>
</UserControl>
