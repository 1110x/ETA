<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.PAGE3.MyTaskPage">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}" />
            <Setter Property="Foreground" Value="{DynamicResource TreeFg}" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#Pretendard" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeSelBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="{DynamicResource TreeHoverBg}" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: 날짜 선택 헤더 -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                CornerRadius="6,6,0,0"
                Padding="8,5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="내 분석업무"
                           FontSize="{DynamicResource FontSizeBase}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource FgMuted}"
                           FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="txtDate"
                               Text=""
                               FontSize="{DynamicResource FontSizeMD}"
                               FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                               Foreground="{DynamicResource AppFg}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnCalToggle"
                            Content="📅"
                            FontSize="13"
                            Padding="4,2"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="날짜 선택"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 인라인 캘린더 -->
        <Border x:Name="calendarHost" Grid.Row="1"/>

        <!-- Row 2: 카테고리 필터 버튼 -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelInnerBg}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="BtnMeokdae"
                        Content="🔬 수질분석센터"
                        Click="CategoryBtn_Click"
                        Tag="수질분석센터"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeBgActiveBlue}"
                        Foreground="{DynamicResource ThemeFgInfo}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeBorderInfo}"/>
                <Button x:Name="BtnWasteCost"
                        Content="💰 비용부담금"
                        Click="CategoryBtn_Click"
                        Tag="비용부담금"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
                <Button x:Name="BtnFacility"
                        Content="⚙ 처리시설"
                        Click="CategoryBtn_Click"
                        Tag="처리시설"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
                <Button x:Name="BtnRequestList"
                        Content="📋 의뢰목록"
                        Click="CategoryBtn_Click"
                        Tag="의뢰목록"
                        FontSize="{DynamicResource FontSizeSM}"
                        FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                        Padding="8,3"
                        CornerRadius="10"
                        Background="{DynamicResource SubBtnBg}"
                        Foreground="{DynamicResource FgMuted}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource InputBorder}"/>
            </StackPanel>
        </Border>

        <!-- Row 3: 트리뷰 -->
        <TreeView Grid.Row="3"
                  x:Name="TaskTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="TaskTreeView_SelectionChanged"/>

    </Grid>
</UserControl>
