<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.DbMigrationPointPanel">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,0" />
            <Setter Property="Margin"     Value="0" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a3a4a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1e2a35" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- 헤더 + 건수 -->
        <Border Grid.Row="0"
                Background="#1a1a28"
                CornerRadius="6,6,0,0"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleSwitch x:Name="tglShowAll"
                              IsChecked="False"
                              OnContent="🌐 전체 보기"
                              OffContent="🔍 선택 업체"
                              FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                              FontSize="11"
                              VerticalAlignment="Center"
                              IsCheckedChanged="TglShowAll_Changed"/>
                <TextBlock x:Name="txbPointCount"
                           Text="—"
                           FontSize="11" Foreground="#888"
                           VerticalAlignment="Center"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R"/>
            </StackPanel>
        </Border>

        <!-- 선택 안내 -->
        <TextBlock Grid.Row="1"
                   x:Name="txbHint"
                   Text="← 왼쪽에서 업체를 선택하세요"
                   FontSize="11" Foreground="#666"
                   FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 R"
                   Margin="8,4,0,2"
                   IsVisible="True"/>

        <!-- 트리뷰 -->
        <Border Grid.Row="2"
                Background="#13131f"
                CornerRadius="0,0,6,6"
                Padding="2,2">
            <TreeView x:Name="PointTreeView"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
        </Border>

    </Grid>
</UserControl>
