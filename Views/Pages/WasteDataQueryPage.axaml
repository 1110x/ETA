<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.WasteDataQueryPage">

    <UserControl.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="Padding"    Value="1,4" />
            <Setter Property="Margin"     Value="0,1" />
            <Setter Property="MinHeight"  Value="0" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="FontFamily" Value="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Padding"    Value="2,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#1a3a2a" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background"   Value="#252535" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="#1a1a28"
                CornerRadius="6,6,0,0"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="자료 조회"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#8899bb"
                           FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="BtnYeosoo"
                        Content="🌊 여수"
                        Click="GroupTab_Click"
                        Tag="여수"
                        FontSize="10"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Padding="8,3" CornerRadius="10"
                        Background="#1e3a5a" Foreground="#88aacc"
                        BorderThickness="1" BorderBrush="#336699"/>
                <Button x:Name="BtnYulchon"
                        Content="🏗 율촌"
                        Click="GroupTab_Click"
                        Tag="율촌"
                        FontSize="10"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Padding="8,3" CornerRadius="10"
                        Background="#222222" Foreground="#666666"
                        BorderThickness="1" BorderBrush="#444444"/>
                <Button x:Name="BtnSepung"
                        Content="🏭 세풍"
                        Click="GroupTab_Click"
                        Tag="세풍"
                        FontSize="10"
                        FontFamily="avares://ETA/Assets/Fonts#KBIZ한마음고딕 M"
                        Padding="8,3" CornerRadius="10"
                        Background="#222222" Foreground="#666666"
                        BorderThickness="1" BorderBrush="#444444"/>
            </StackPanel>
        </Border>
        <TreeView Grid.Row="1"
                  x:Name="WasteCompanyTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SelectionChanged="WasteCompanyTreeView_SelectionChanged" />
    </Grid>

</UserControl>
