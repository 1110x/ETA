<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Views.Pages.WasteCompanyPage">

    <Grid>
        <TreeView x:Name="WasteCompanyTreeView"
                  Margin="5"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">

            <!-- ★★★ 하얀 박스 완전 제거 스타일 ★★★ -->
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>

                <!-- Expander (삼각형 + 하얀 박스) 완전 숨김 -->
                <Style Selector="TreeViewItem > ToggleButton">
                    <Setter Property="Width" Value="0" />
                    <Setter Property="Height" Value="0" />
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="IsVisible" Value="False" />
                </Style>
            </TreeView.Styles>
        </TreeView>

        <!-- 상태창 -->
        <Border Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                CornerRadius="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10"
                Padding="16,9">
            <!--TextBlock x:Name="StatusText"
            Text="트리 로드 중..."
            FontSize="14"
            Foreground="#FFAA00"/-->
        </Border>

        <!-- ★★★ 전체 저장 버튼 ★★★ -->
        <Button x:Name="SaveAllButton"
                Content="전체 저장 (DB 업데이트)"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,20,20,0"
                Padding="20,10"
                FontSize="14"
                Background="#19ab708f"
                Foreground="White"
                IsVisible="False"
                Click="SaveAllButton_Click" />
    </Grid>
</UserControl>