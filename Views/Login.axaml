<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lottie="using:Avalonia.Labs.Lottie"
        d:DesignWidth="920" d:DesignHeight="580"
        x:Class="ETA.Views.Login"
        Title="RENEWUS TEAM Water Analysis Center"
        Icon="avares://ETA/Assets/icons/ETA.ico"
        Width="800" Height="650"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- ══ 로그인 카드 등장 애니메이션 (페이드+슬라이드업) ══ -->
        <Style Selector="Border#loginForm">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:0.7" Easing="CubicEaseOut" FillMode="Forward" Delay="0:0:0.1">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="40"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslateTransform.Y" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- ══ 버튼 호버/프레스 스케일 효과 ══ -->
        <Style Selector="Button">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform" Value="scaleX(1) scaleY(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scaleX(1.03) scaleY(1.03)"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scaleX(0.96) scaleY(0.96)"/>
        </Style>

        <!-- ══ 입력 포커스 강조 + 호버 배경 ══ -->
        <Style Selector="TextBox">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <ThicknessTransition Property="BorderThickness" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#3B6FE8"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F8FAFF"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F0F4FF"/>
        </Style>

        <!-- ══ 에러 메시지 페이드인 ══ -->
        <Style Selector="TextBlock#txtError">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ══ DB 선택 ComboBox — 항상 테두리/배경 표시 ══ -->
        <Style Selector="ComboBox#cmbDb /template/ Border#Background">
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBox#cmbDb:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="#F0F4FF"/>
            <Setter Property="BorderBrush" Value="#3B6FE8"/>
        </Style>
        <Style Selector="ComboBox#cmbDb:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="#3B6FE8"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- ══ 회원가입 링크 호버 효과 ══ -->
        <Style Selector="TextBlock#lnkSignUp">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock#lnkSignUp:pointerover">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
    </Window.Styles>

    <Grid>

        <!-- 배경 -->
        <Border Background="#EEF2FF" />

        <!-- Lottie: 처음부터 보이되 멈춤, 로그인 성공 시 재생 -->
        <lottie:Lottie x:Name="lottieView"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Path="avares://ETA/Assets/Videos/Loadercat.json"
                       AutoPlay="False"
                       RepeatCount="-1"
                       Stretch="UniformToFill" />

        <!-- 서버 연결 진행 오버레이 (로그인 성공 후 표시) -->
        <Border x:Name="connectOverlay"
                IsVisible="False"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Padding="40,0,40,32">
            <Border Background="#CC0a0a18"
                    CornerRadius="12"
                    Padding="24,16">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="txtConnectStatus"
                                   Grid.Column="0"
                                   Text="서버 연결 중..."
                                   Foreground="White"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>
                        <TextBlock x:Name="txtConnectPct"
                                   Grid.Column="1"
                                   Text="0%"
                                   Foreground="#88ffffff"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"/>
                    </Grid>
                    <ProgressBar x:Name="pbConnect"
                                 Minimum="0" Maximum="100" Value="0"
                                 Height="7"
                                 CornerRadius="4">
                        <ProgressBar.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Value" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                            </Transitions>
                        </ProgressBar.Transitions>
                    </ProgressBar>
                </StackPanel>
            </Border>
        </Border>

        <!-- 로그인 카드 (초기화 완료 후 표시) -->
        <Border x:Name="loginForm"
                IsVisible="False"
                Background="White"
                CornerRadius="16"
                Padding="48,40"
                Width="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.BoxShadow>0 8 32 0 #1A3B6FE8</Border.BoxShadow>

            <StackPanel Spacing="10">

                <!-- 타이틀 -->
                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                    <!-- 로고 이미지 -->
                    <Image Grid.Column="0"
                           Source="avares://ETA/Assets/icons/ETA.ico"
                           Width="64" Height="64"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                    <!-- 텍스트 -->
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitle" Text="RENEWUS ETA SYSTEM" FontSize="17" FontWeight="Bold"
                                   Foreground="#003cc9"
                                   PointerPressed="Title_Click"/>
                        <TextBlock Text="TEAM Professional WATER ANALYSIS CENTER" FontSize="9"
                                   Foreground="#9CA3AF" TextWrapping="Wrap"/>
                        <TextBlock Text="Presented by 1110x v1.0" FontSize="10" FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                                   Foreground="#5a2da1"/>
                    </StackPanel>
                </Grid>

                <!-- DB 선택 -->
                <StackPanel Spacing="5">
                    <TextBlock Text="데이터베이스" FontSize="{DynamicResource FontSizeSM}" FontWeight="SemiBold"
                               Foreground="#6B7280"/>
                    <ComboBox x:Name="cmbDb"
                              HorizontalAlignment="Stretch"
                              Padding="10,9"
                              FontSize="{DynamicResource FontSizeBase}"
                              FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                              SelectionChanged="CmbDb_SelectionChanged"/>
                </StackPanel>

                <!-- 사번 입력 -->
                <StackPanel Spacing="10">
                    <TextBlock Text="사번" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox x:Name="txtEmail" Watermark="202912345" FontSize="{DynamicResource FontSizeXL}"
                             Padding="12,12" CornerRadius="9"
                             BorderBrush="{DynamicResource LoginInputBorder}" BorderThickness="1.5"
                             Background="#F8FAFF" Foreground="#111827"
                             LetterSpacing="3"/>
                </StackPanel>

                <!-- 비밀번호 입력 -->
                <StackPanel Spacing="10">
                    <TextBlock Text="비밀번호" FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold"
                               Foreground="#374151"/>
                    <TextBox x:Name="txtPassword"
                             Watermark="초기 비밀번호: 123456"
                             FontSize="{DynamicResource FontSizeXL}" Padding="12,12" CornerRadius="9"
                             BorderBrush="{DynamicResource LoginInputBorder}" BorderThickness="1.5"
                             Background="#F8FAFF" Foreground="#111827"
                             LetterSpacing="3"/>
                </StackPanel>

                <!-- 오류 메시지 -->
                <TextBlock x:Name="txtError" Text="" FontSize="{DynamicResource FontSizeLG}"
                           Foreground="#EF4444"
                           IsVisible="False" TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

                <!-- 버튼들 -->
                <!-- 로그인 처리 중 진행 표시 -->
                <ProgressBar x:Name="pbLoginLoading"
                             IsVisible="False"
                             IsIndeterminate="True"
                             Height="4"
                             CornerRadius="2"
                             Margin="0,4,0,0"/>

                <StackPanel Spacing="10" Margin="0,8,0,0">
                    <Button Content="로그인" Click="Login_Click"
                            FontSize="{DynamicResource FontSizeLG}" FontWeight="SemiBold"
                            Padding="0,14" CornerRadius="10" BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="#3B6FE8" Foreground="White">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#2952CC"/>
                            </Style>
                            <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#1E3EA8"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                Content="비밀번호 찾기"
                                Click="ChangePassword_Click"
                                FontSize="{DynamicResource FontSizeLG}" Padding="8,9"
                                CornerRadius="8" BorderThickness="1.5"
                                BorderBrush="{DynamicResource LoginInputBorder}"
                                Background="White" Foreground="#374151"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#EEF2FF"/>
                                </Style>
                            </Button.Styles>
                        </Button>

                        <TextBlock Grid.Column="1"
                                   x:Name="lnkSignUp" Text="회원가입"
                                   Foreground="#3B6FE8" FontSize="{DynamicResource FontSizeLG}"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   PointerPressed="SignUp_Click"/>
                    </Grid>
                </StackPanel>


            </StackPanel>
        </Border>

        <!-- 앱 시작 초기화 오버레이 -->
        <Border x:Name="startupOverlay"
                Background="White"
                CornerRadius="16"
                Padding="48,40"
                Width="380"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.BoxShadow>0 8 32 0 #1A3B6FE8</Border.BoxShadow>
            <StackPanel Spacing="20">
                <!-- 로고 -->
                <Grid ColumnDefinitions="Auto,*">
                    <Image Grid.Column="0"
                           Source="avares://ETA/Assets/icons/ETA.ico"
                           Width="64" Height="64"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="RENEWUS ETA SYSTEM" FontSize="17" FontWeight="Bold"
                                   Foreground="#003cc9"/>
                        <TextBlock Text="TEAM Professional WATER ANALYSIS CENTER"
                                   FontSize="9" Foreground="#9CA3AF" TextWrapping="Wrap"/>
                        <TextBlock Text="Presented by 1110x v1.0" FontSize="10"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                                   Foreground="#5a2da1"/>
                    </StackPanel>
                </Grid>
                <!-- 진행 표시 -->
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="txtStartupStatus"
                                   Grid.Column="0"
                                   Text="시스템 초기화 중..."
                                   FontSize="13"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtStartupPct"
                                   Grid.Column="1"
                                   Text="0%"
                                   FontSize="11"
                                   FontFamily="avares://ETA/Assets/Fonts#Pretendard"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ProgressBar x:Name="pbStartup"
                                 Minimum="0" Maximum="100" Value="0"
                                 Height="7"
                                 CornerRadius="4">
                        <ProgressBar.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Value" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                            </Transitions>
                        </ProgressBar.Transitions>
                    </ProgressBar>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
