<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        d:DesignWidth="920" d:DesignHeight="580"
        x:Class="ETA.Views.Login"
        Title="RENEWUS TEAM Water Analysis Center"
        Icon="avares://ETA/Assets/icons/ETA.ico"
        Width="450" Height="650"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- 배경 (비디오 대신 검은색) -->
        <Border Background="#000000" />

        <!-- 오버레이 -->
        <Border Background="#00000080" />

        <!-- 로그인 폼 -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="20" Margin="40">

            <!-- 사번 입력 -->
            <StackPanel Spacing="5">
                <TextBlock Text="사번" FontSize="14" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBox x:Name="txtEmail" Watermark="202912345" FontSize="14"
                         Padding="12,11" CornerRadius="9"
                         BorderBrush="#FFFFFF" BorderThickness="1"
                         Background="#FFFFFFCC"/>
            </StackPanel>

            <!-- 비밀번호 입력 -->
            <StackPanel Spacing="5">
                <TextBlock Text="비밀번호" FontSize="14" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBox x:Name="txtPassword"
                         Watermark="초기 비밀번호: 123456"
                         PasswordChar="*"
                         FontSize="14" Padding="12,11" CornerRadius="9"
                         BorderBrush="#FFFFFF" BorderThickness="1"
                         Background="#FFFFFFCC"/>
            </StackPanel>

            <!-- 오류 메시지 -->
            <TextBlock x:Name="txtError" Text="" FontSize="13"
                       Foreground="#FFAAAA"
                       IsVisible="False" TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

            <!-- 버튼들 -->
            <StackPanel Spacing="10" Margin="0,20,0,0">
                <Button Content="로그인" Click="Login_Click"
                        FontSize="16" FontWeight="SemiBold"
                        Padding="0,16" CornerRadius="11" BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#0F766E" Foreground="White">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#14A38E"/>
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#0C5F58"/>
                        </Style>
                    </Button.Styles>
                </Button>

                <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0"
                            Content="비밀번호 찾기"
                            Click="ChangePassword_Click"
                            FontSize="14" Padding="8,8"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="#FFFFFF"
                            Background="#FFFFFFCC" Foreground="#000000"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <TextBlock Grid.Column="1"
                               x:Name="lnkSignUp" Text="회원가입"
                               Foreground="#FFFFFF" FontSize="14"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               PointerPressed="SignUp_Click"/>
                </Grid>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
