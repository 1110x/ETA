<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ETA.Views.ChangePasswordWindow"
        Title="비밀번호 변경"
        Width="420" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#F8FAFC"
        Icon="avares://ETA/Assets/icons/ETA.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Margin="0" Padding="36,28"
            Background="White" CornerRadius="20"
            BorderBrush="#E2E8F0" BorderThickness="1"
            BoxShadow="0 12 32 0 #00000016">

        <StackPanel Spacing="14">

            <!-- 헤더 -->
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="🔐" FontSize="{DynamicResource FontSizeHuge}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtTitle" Text="비밀번호 변경"
                           FontSize="{DynamicResource FontSizeTitle}" FontWeight="Bold"
                           Foreground="#0F172A" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtSubtitle"
                           Text="초기 비밀번호를 변경해주세요."
                           FontSize="{DynamicResource FontSizeLG}" Foreground="#64748B"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- 안내 배너 (최초 변경 시에만 표시) -->
            <Border x:Name="bannerInitial"
                    Background="#FFF7ED" CornerRadius="8"
                    BorderBrush="#FED7AA" BorderThickness="1"
                    Padding="12,10" IsVisible="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="⚠" FontSize="{DynamicResource FontSizeXL}" Foreground="#EA580C" VerticalAlignment="Top"/>
                    <TextBlock Text="초기 비밀번호(123456)가 설정되어 있습니다.&#x0a;보안을 위해 반드시 변경 후 로그인하세요."
                               FontSize="{DynamicResource FontSizeMD}" Foreground="#9A3412" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 현재 비밀번호 -->
            <StackPanel Spacing="5">
                <TextBlock Text="현재 비밀번호" FontSize="{DynamicResource FontSizeLG}" Foreground="#64748B"/>
                <TextBox x:Name="txtCurrent" PasswordChar="*"
                         Watermark="현재 비밀번호 입력"
                         FontSize="{DynamicResource FontSizeXL}" Padding="12,10" CornerRadius="9"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>
            </StackPanel>

            <!-- 새 비밀번호 -->
            <StackPanel Spacing="5">
                <TextBlock Text="새 비밀번호" FontSize="{DynamicResource FontSizeLG}" Foreground="#64748B"/>
                <TextBox x:Name="txtNew" PasswordChar="*"
                         Watermark="최소 6자 이상"
                         FontSize="{DynamicResource FontSizeXL}" Padding="12,10" CornerRadius="9"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>
                <!-- 강도 표시 바 -->
                <Grid ColumnDefinitions="*,*,*" Height="4" Margin="0,4,0,0">
                    <Border x:Name="barWeak"   Grid.Column="0" CornerRadius="2" Background="#E2E8F0" Margin="0,0,3,0"/>
                    <Border x:Name="barMedium" Grid.Column="1" CornerRadius="2" Background="#E2E8F0" Margin="0,0,3,0"/>
                    <Border x:Name="barStrong" Grid.Column="2" CornerRadius="2" Background="#E2E8F0"/>
                </Grid>
                <TextBlock x:Name="txtStrength" Text="" FontSize="{DynamicResource FontSizeBase}"
                           Foreground="#94A3B8" HorizontalAlignment="Right"/>
            </StackPanel>

            <!-- 비밀번호 확인 -->
            <StackPanel Spacing="5">
                <TextBlock Text="새 비밀번호 확인" FontSize="{DynamicResource FontSizeLG}" Foreground="#64748B"/>
                <TextBox x:Name="txtConfirm" PasswordChar="*"
                         Watermark="새 비밀번호 재입력"
                         FontSize="{DynamicResource FontSizeXL}" Padding="12,10" CornerRadius="9"
                         BorderBrush="#CBD5E1" BorderThickness="1"/>
            </StackPanel>

            <!-- 오류 메시지 -->
            <TextBlock x:Name="txtError" Text="" FontSize="{DynamicResource FontSizeMD}"
                       Foreground="#EF4444" IsVisible="False"
                       TextWrapping="Wrap" HorizontalAlignment="Center"/>

            <!-- 버튼 영역 -->
            <Grid ColumnDefinitions="*,12,*" Margin="0,2,0,0">
                <!-- 취소 (최초 강제 변경 시 숨김) -->
                <Button x:Name="btnCancel" Grid.Column="0"
                        Content="취소" Click="Cancel_Click"
                        FontSize="{DynamicResource FontSizeXL}" Padding="0,13" CornerRadius="9"
                        BorderThickness="1" BorderBrush="#E2E8F0"
                        Background="White" Foreground="#475569"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>

                <!-- 변경 -->
                <Button Grid.Column="2"
                        Content="변경하기" Click="Confirm_Click"
                        FontSize="{DynamicResource FontSizeXL}" FontWeight="SemiBold"
                        Padding="0,13" CornerRadius="9" BorderThickness="0"
                        Background="#0F766E" Foreground="White"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#14A38E"/>
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#0C5F58"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
    </ScrollViewer>
</Window>
