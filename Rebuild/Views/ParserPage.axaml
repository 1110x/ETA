<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.Rebuild.Views.ParserPage">

    <Grid Margin="16" ColumnDefinitions="260,12,*,12,320" RowDefinitions="*">

        <!-- ══════════════════════════════════════════════════════════
             SHOW1 · 주간 스트립 + 원본 로그 배치 리스트
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto,*">

                <Border Grid.Row="0" Classes="card-head">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="⚙ 파서" Classes="h3"/>
                        <Border Grid.Column="1" Classes="chip warn"><TextBlock Text="미매칭 7"/></Border>
                    </Grid>
                </Border>

                <!-- 주간 스트립 -->
                <Border Grid.Row="1" Classes="card-flat" Margin="8,8,8,6" Padding="8,6">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Grid.RowSpan="2" Orientation="Vertical"
                                    VerticalAlignment="Center" Margin="0,0,10,0" Spacing="2">
                            <Button Content="▲" Classes="weekNav" ToolTip.Tip="이전 주"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="📅" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="이번 주" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="▼" Classes="weekNav" ToolTip.Tip="다음 주"/>
                        </StackPanel>

                        <Grid Grid.Column="1" Grid.Row="0" ColumnDefinitions="*,*,*,*,*,*,*">
                            <TextBlock Grid.Column="0" Text="월" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="화" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="수" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="목" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="금" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="토" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="일" Classes="muted" FontSize="9" HorizontalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Column="1" Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,2,0,0">
                            <Border Grid.Column="0" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="13" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="14" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="15" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="16" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="17" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="5" Width="24" Height="24" HorizontalAlignment="Center">
                                <TextBlock Text="18" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="6" Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource PaperAccent}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="19" FontSize="13" FontWeight="Bold"
                                           Foreground="#1a1a1a"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 파서 상태 -->
                <Border Grid.Row="2" Classes="card-flat" Margin="8,2,8,6" Padding="10,8">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="감시 폴더" Classes="h3"/>
                        <Border Grid.Row="0" Grid.Column="1" Classes="chip ok"><TextBlock Text="가동"/></Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Data/측정인 · 자동 감지" Classes="muted"/>
                        <Button Grid.Row="1" Grid.Column="1" Classes="ghost" Content="폴더" Padding="8,2" FontSize="10"/>
                    </Grid>
                </Border>

                <!-- 원본 로그 배치 리스트 -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Spacing="6">

                        <TextBlock Text="📂 원본 파일" Classes="muted" Margin="4,4,0,0"/>

                        <Border Classes="row-active" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="일일 배치 · 04-19" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip warn"><TextBlock Text="미매칭 3"/></Border>
                                </Grid>
                                <TextBlock Text="8개 파일 · 126 rows" Classes="muted"/>
                                <TextBlock Text="마지막 파싱 10:42" Classes="sub"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="BOD_0419.log" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="✓"/></Border>
                                </Grid>
                                <TextBlock Text="42 rows · 정도관리 4" Classes="muted"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="TOC_0419.csv" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip warn"><TextBlock Text="2"/></Border>
                                </Grid>
                                <TextBlock Text="28 rows · 미매칭 2" Classes="muted"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="COD_0419.log" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="✓"/></Border>
                                </Grid>
                                <TextBlock Text="36 rows · 정도관리 3" Classes="muted"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="TN_TP_0419.xlsx" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip warn"><TextBlock Text="1"/></Border>
                                </Grid>
                                <TextBlock Text="20 rows · 미매칭 1" Classes="muted"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="📦 이전 배치" Classes="muted" Margin="4,10,0,0"/>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="일일 배치 · 04-18" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="저장"/></Border>
                                </Grid>
                                <TextBlock Text="8개 파일 · 131 rows · 저장됨" Classes="muted"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="row" Padding="10,6">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="일일 배치 · 04-17" Classes="h3"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="저장"/></Border>
                                </Grid>
                                <TextBlock Text="7개 파일 · 118 rows · 저장됨" Classes="muted"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             SHOW2 · 파싱 프리뷰 매트릭스 (시료 × 항목)
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Classes="card">
            <Grid RowDefinitions="Auto,*,Auto">

                <Border Grid.Row="0" Classes="card-head">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <Border Classes="sectag" Width="22" Height="22">
                                <TextBlock Text="2" FontSize="11"/>
                            </Border>
                            <TextBlock Text="일일 배치 · 04-19 · 파싱 프리뷰"
                                       Classes="h3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Border Classes="chip info"><TextBlock Text="8 시료 × 7 항목"/></Border>
                            <Button Classes="ghost" Content="🔍 원본 보기"/>
                            <Button Classes="primary" Content="💾 저장"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Margin="12" Classes="card-flat" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Classes="th"><TextBlock Text="시료 약칭 → 매칭"/></Border>
                            <Border Grid.Row="0" Grid.Column="1" Classes="th"><TextBlock Text="pH"/></Border>
                            <Border Grid.Row="0" Grid.Column="2" Classes="th"><TextBlock Text="BOD"/></Border>
                            <Border Grid.Row="0" Grid.Column="3" Classes="th"><TextBlock Text="COD"/></Border>
                            <Border Grid.Row="0" Grid.Column="4" Classes="th"><TextBlock Text="TOC"/></Border>
                            <Border Grid.Row="0" Grid.Column="5" Classes="th"><TextBlock Text="SS"/></Border>
                            <Border Grid.Row="0" Grid.Column="6" Classes="th"><TextBlock Text="T-N"/></Border>
                            <Border Grid.Row="0" Grid.Column="7" Classes="th"><TextBlock Text="T-P"/></Border>

                            <!-- 원수 -->
                            <Border Grid.Row="1" Grid.Column="0" Classes="td">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="WS-01 → 원수" Classes="body" HorizontalAlignment="Left"/>
                                    <TextBlock Text="BL-0089-01" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Classes="td"><TextBlock Text="7.1"/></Border>
                            <Border Grid.Row="1" Grid.Column="2" Classes="td"><TextBlock Text="142"/></Border>
                            <Border Grid.Row="1" Grid.Column="3" Classes="td"><TextBlock Text="218"/></Border>
                            <Border Grid.Row="1" Grid.Column="4" Classes="td"><TextBlock Text="68.4"/></Border>
                            <Border Grid.Row="1" Grid.Column="5" Classes="td"><TextBlock Text="184"/></Border>
                            <Border Grid.Row="1" Grid.Column="6" Classes="td"><TextBlock Text="38.2"/></Border>
                            <Border Grid.Row="1" Grid.Column="7" Classes="td"><TextBlock Text="4.62"/></Border>

                            <!-- 배출구-1 -->
                            <Border Grid.Row="2" Grid.Column="0" Classes="td">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="OUT-1 → 배출구-1" Classes="body" HorizontalAlignment="Left"/>
                                    <TextBlock Text="BL-0089-02" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" Classes="td"><TextBlock Text="7.3"/></Border>
                            <Border Grid.Row="2" Grid.Column="2" Classes="td"><TextBlock Text="4.2"/></Border>
                            <Border Grid.Row="2" Grid.Column="3" Classes="td"><TextBlock Text="12.8"/></Border>
                            <Border Grid.Row="2" Grid.Column="4" Classes="td"><TextBlock Text="6.1"/></Border>
                            <Border Grid.Row="2" Grid.Column="5" Classes="td"><TextBlock Text="3.1"/></Border>
                            <Border Grid.Row="2" Grid.Column="6" Classes="td"><TextBlock Text="8.4"/></Border>
                            <Border Grid.Row="2" Grid.Column="7" Classes="td"><TextBlock Text="0.82"/></Border>

                            <!-- 배출구-2 -->
                            <Border Grid.Row="3" Grid.Column="0" Classes="td">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="OUT-2 → 배출구-2" Classes="body" HorizontalAlignment="Left"/>
                                    <TextBlock Text="BL-0089-03" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="3" Grid.Column="1" Classes="td"><TextBlock Text="7.0"/></Border>
                            <Border Grid.Row="3" Grid.Column="2" Classes="td"><TextBlock Text="5.8"/></Border>
                            <Border Grid.Row="3" Grid.Column="3" Classes="td"><TextBlock Text="16.4"/></Border>
                            <Border Grid.Row="3" Grid.Column="4" Classes="td"><TextBlock Text="7.9"/></Border>
                            <Border Grid.Row="3" Grid.Column="5" Classes="td"><TextBlock Text="4.2"/></Border>
                            <Border Grid.Row="3" Grid.Column="6" Classes="td"><TextBlock Text="10.1"/></Border>
                            <Border Grid.Row="3" Grid.Column="7" Classes="td"><TextBlock Text="1.12"/></Border>

                            <!-- 공정수 A (미매칭 행) -->
                            <Border Grid.Row="4" Grid.Column="0" Classes="td" Background="{DynamicResource PaperWarnBg}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="PR-A → ?" Classes="body" FontWeight="Bold"
                                               Foreground="{DynamicResource PaperWarnFg}" HorizontalAlignment="Left"/>
                                    <TextBlock Text="미매칭 · 수동 매칭 필요" Classes="sub"
                                               Foreground="{DynamicResource PaperWarnFg}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="4" Grid.Column="1" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="6.9"/></Border>
                            <Border Grid.Row="4" Grid.Column="2" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="98"/></Border>
                            <Border Grid.Row="4" Grid.Column="3" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="164"/></Border>
                            <Border Grid.Row="4" Grid.Column="4" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="54.2"/></Border>
                            <Border Grid.Row="4" Grid.Column="5" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="128"/></Border>
                            <Border Grid.Row="4" Grid.Column="6" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="28.4"/></Border>
                            <Border Grid.Row="4" Grid.Column="7" Classes="td" Background="{DynamicResource PaperWarnBg}"><TextBlock Text="3.84"/></Border>

                            <!-- 공정수 B -->
                            <Border Grid.Row="5" Grid.Column="0" Classes="td">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="PR-B → 공정수 B" Classes="body" HorizontalAlignment="Left"/>
                                    <TextBlock Text="BL-0089-05" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="5" Grid.Column="1" Classes="td"><TextBlock Text="7.2"/></Border>
                            <Border Grid.Row="5" Grid.Column="2" Classes="td"><TextBlock Text="6.4"/></Border>
                            <Border Grid.Row="5" Grid.Column="3" Classes="td"><TextBlock Text="18.2"/></Border>
                            <Border Grid.Row="5" Grid.Column="4" Classes="td"><TextBlock Text="8.8"/></Border>
                            <Border Grid.Row="5" Grid.Column="5" Classes="td"><TextBlock Text="5.6"/></Border>
                            <Border Grid.Row="5" Grid.Column="6" Classes="td"><TextBlock Text="11.8"/></Border>
                            <Border Grid.Row="5" Grid.Column="7" Classes="td"><TextBlock Text="1.24"/></Border>

                            <!-- QC 시료 — BK -->
                            <Border Grid.Row="6" Grid.Column="0" Classes="td" Background="{DynamicResource PaperInfoBgSoft}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="BK → 정도관리" Classes="body" HorizontalAlignment="Left"
                                               Foreground="{DynamicResource PaperInfoFg}"/>
                                    <TextBlock Text="Blank" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="6" Grid.Column="1" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="7.0"/></Border>
                            <Border Grid.Row="6" Grid.Column="2" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.1"/></Border>
                            <Border Grid.Row="6" Grid.Column="3" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.2"/></Border>
                            <Border Grid.Row="6" Grid.Column="4" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.1"/></Border>
                            <Border Grid.Row="6" Grid.Column="5" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="ND"/></Border>
                            <Border Grid.Row="6" Grid.Column="6" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.04"/></Border>
                            <Border Grid.Row="6" Grid.Column="7" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="ND"/></Border>

                            <!-- QC — CCV -->
                            <Border Grid.Row="7" Grid.Column="0" Classes="td" Background="{DynamicResource PaperInfoBgSoft}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="CCV → 정도관리" Classes="body" HorizontalAlignment="Left"
                                               Foreground="{DynamicResource PaperInfoFg}"/>
                                    <TextBlock Text="Check Std" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="7" Grid.Column="1" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="7.00"/></Border>
                            <Border Grid.Row="7" Grid.Column="2" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="20.2"/></Border>
                            <Border Grid.Row="7" Grid.Column="3" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="50.1"/></Border>
                            <Border Grid.Row="7" Grid.Column="4" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="25.1"/></Border>
                            <Border Grid.Row="7" Grid.Column="5" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="—"/></Border>
                            <Border Grid.Row="7" Grid.Column="6" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="10.0"/></Border>
                            <Border Grid.Row="7" Grid.Column="7" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="1.02"/></Border>

                            <!-- QC — DW -->
                            <Border Grid.Row="8" Grid.Column="0" Classes="td" Background="{DynamicResource PaperInfoBgSoft}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="DW → 정도관리" Classes="body" HorizontalAlignment="Left"
                                               Foreground="{DynamicResource PaperInfoFg}"/>
                                    <TextBlock Text="Distilled W" Classes="sub"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="8" Grid.Column="1" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="6.8"/></Border>
                            <Border Grid.Row="8" Grid.Column="2" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.1"/></Border>
                            <Border Grid.Row="8" Grid.Column="3" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.3"/></Border>
                            <Border Grid.Row="8" Grid.Column="4" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.2"/></Border>
                            <Border Grid.Row="8" Grid.Column="5" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="ND"/></Border>
                            <Border Grid.Row="8" Grid.Column="6" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="0.05"/></Border>
                            <Border Grid.Row="8" Grid.Column="7" Classes="td" Background="{DynamicResource PaperInfoBgSoft}"><TextBlock Text="ND"/></Border>

                        </Grid>
                    </Border>
                </ScrollViewer>

                <!-- 하단 작업 바 -->
                <Border Grid.Row="2" Classes="card-head" BorderThickness="0,1.2,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Classes="chip ok"><TextBlock Text="● 매칭 4"/></Border>
                            <Border Classes="chip warn"><TextBlock Text="▲ 미매칭 1"/></Border>
                            <Border Classes="chip info"><TextBlock Text="🔬 정도관리 3"/></Border>
                            <TextBlock Text="8 rows · BOD_DATA / TOC_DATA / …" Classes="muted" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Classes="ghost" Content="🔁 다시 파싱"/>
                            <Button Classes="ghost" Content="🎯 수동 매칭"/>
                            <Button Classes="primary" Content="💾 DATA 저장"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             SHOW4 · 파싱 요약 · 미매칭 · 규칙
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="4" Classes="card">
            <Grid RowDefinitions="Auto,*">

                <Border Grid.Row="0" Classes="card-head">
                    <TextBlock Text="🧩 파싱 상세" Classes="h3"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12" Spacing="12">

                        <!-- 오늘 요약 -->
                        <Border Classes="card-flat" Padding="12,10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📊 오늘 (04-19)" Classes="h3"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="파싱된 rows" Classes="body"/>
                                    <TextBlock Grid.Column="1" Text="126" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="매칭 성공" Classes="body"/>
                                    <TextBlock Grid.Column="1" Text="119"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PaperOkFg}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="미매칭" Classes="body"/>
                                    <TextBlock Grid.Column="1" Text="7"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PaperAccent}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="정도관리 감지" Classes="body"/>
                                    <TextBlock Grid.Column="1" Text="BK 4 · CCV 4 · DW 3"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PaperInfoFg}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 미매칭 약칭 -->
                        <Border Classes="card-flat" Padding="12,10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="⚠ 미매칭 약칭" Classes="h3"/>

                                <Border BorderBrush="{DynamicResource PaperInkHair}" BorderThickness="0,0,0,1" Padding="0,4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="1">
                                            <TextBlock Text="PR-A" FontWeight="SemiBold"/>
                                            <TextBlock Text="TOC_0419.csv  R24" Classes="sub"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="ghost" Content="매칭" Padding="8,2" FontSize="10"/>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{DynamicResource PaperInkHair}" BorderThickness="0,0,0,1" Padding="0,4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="1">
                                            <TextBlock Text="TEMP-X" FontWeight="SemiBold"/>
                                            <TextBlock Text="TOC_0419.csv  R31" Classes="sub"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="ghost" Content="매칭" Padding="8,2" FontSize="10"/>
                                    </Grid>
                                </Border>

                                <Border Padding="0,4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="1">
                                            <TextBlock Text="LAB-OLD" FontWeight="SemiBold"/>
                                            <TextBlock Text="TN_TP_0419.xlsx  R12" Classes="sub"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="ghost" Content="매칭" Padding="8,2" FontSize="10"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 활성 규칙 -->
                        <Border Classes="card-flat" Padding="12,10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="🧬 활성 파서 규칙" Classes="h3"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="BOD · 탭 구분 .log" Classes="body"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="v3"/></Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="TOC · CSV 헤더 6행" Classes="body"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="v2"/></Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="COD · 탭 구분 .log" Classes="body"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="v3"/></Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="T-N/T-P · xlsx" Classes="body"/>
                                    <Border Grid.Column="1" Classes="chip ok"><TextBlock Text="v1"/></Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 연관 -->
                        <Border Classes="card-flat" Padding="12,10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="📓 연관 자료" Classes="h3"/>
                                <TextBlock Text="· 화합물별명 테이블" Classes="body"/>
                                <TextBlock Text="· BOD_DATA · TOC_DATA 등 *_DATA" Classes="body"/>
                                <TextBlock Text="· 파서 규칙 관리" Classes="body"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
