<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ETA.App"

             RequestedThemeVariant="Dark">  <!-- 여기서 Light 지정 (Default면 시스템 따라감) -->

             <Application.Resources>
                 <FontFamily x:Key="KBIZFont">avares://ETA/Assets/Fonts#Pretendard</FontFamily>

                 <!-- ══════════════════════════════════════════════════
                      전역 테마 리소스 — 테마 변경 시 여기만 수정
                      ══════════════════════════════════════════════════ -->

                 <!-- 보더 (Border) -->
                 <SolidColorBrush x:Key="ThemeBorderDefault"   Color="#555577"/>  <!-- 표준 패널/카드 -->
                 <SolidColorBrush x:Key="ThemeBorderSubtle"    Color="#333344"/>  <!-- 내부/약한 보더 -->
                 <SolidColorBrush x:Key="ThemeBorderMuted"     Color="#404050"/>  <!-- 비활성/보조 -->
                 <SolidColorBrush x:Key="ThemeBorderActive"    Color="#2a6a2a"/>  <!-- 활성/선택 (초록) -->
                 <SolidColorBrush x:Key="ThemeBorderInfo"      Color="#336699"/>  <!-- 정보/선택 (파랑) -->
                 <SolidColorBrush x:Key="ThemeBorderAccent"    Color="#3a5a8a"/>  <!-- 강조 (파랑) -->
                 <SolidColorBrush x:Key="ThemeBorderDanger"    Color="#663333"/>  <!-- 위험/경고 (빨강) -->
                 <SolidColorBrush x:Key="ThemeBorderWarn"      Color="#6a5a3a"/>  <!-- 주의 (앰버) -->
                 <SolidColorBrush x:Key="ThemeBorderSeparator" Color="#3a3a4a"/>  <!-- 구분선 -->
                 <SolidColorBrush x:Key="ThemeBorderPanel"     Color="#3a3a4a"/>  <!-- 패널 외곽 -->

                 <!-- 전경색 (Foreground) — 테마 전환 대비 -->
                 <SolidColorBrush x:Key="ThemeFgPrimary"       Color="#ffffff"/>
                 <SolidColorBrush x:Key="ThemeFgSecondary"     Color="#cccccc"/>
                 <SolidColorBrush x:Key="ThemeFgMuted"         Color="#888899"/>
                 <SolidColorBrush x:Key="ThemeFgDimmed"        Color="#555566"/>
                 <SolidColorBrush x:Key="ThemeFgSuccess"       Color="#88cc88"/>
                 <SolidColorBrush x:Key="ThemeFgInfo"          Color="#88aacc"/>
                 <SolidColorBrush x:Key="ThemeFgDanger"        Color="#ff6666"/>
                 <SolidColorBrush x:Key="ThemeFgWarn"          Color="#ffaa44"/>
                 <SolidColorBrush x:Key="ThemeFgLink"          Color="#88aaff"/>

                 <!-- 배경색 (Background) -->
                 <SolidColorBrush x:Key="ThemeBgPrimary"       Color="#1e1e26"/>
                 <SolidColorBrush x:Key="ThemeBgSecondary"     Color="#252535"/>
                 <SolidColorBrush x:Key="ThemeBgCard"          Color="#2a2a3a"/>
                 <SolidColorBrush x:Key="ThemeBgInput"         Color="#22223a"/>
                 <SolidColorBrush x:Key="ThemeBgActiveGreen"   Color="#1a3a1a"/>
                 <SolidColorBrush x:Key="ThemeBgActiveBlue"    Color="#1e3a5a"/>
                 <SolidColorBrush x:Key="ThemeBgDanger"        Color="#4a2a2a"/>

                 <!-- 로그인 전용 -->
                 <SolidColorBrush x:Key="LoginInputBorder"     Color="#D1D9FF"/>
                 <SolidColorBrush x:Key="LoginCardBorder"      Color="#C7D2FE"/>
                 <SolidColorBrush x:Key="LoginActionBorder"    Color="#2a5a3a"/>
                 <SolidColorBrush x:Key="LoginMutedBorder"     Color="#3a3a55"/>

                 <!-- 의미 상태 토큰 (배지/프로그레스바 통일) — wireframe v0.1 -->
                 <SolidColorBrush x:Key="StatusOkBg"           Color="#1a3a2a"/>
                 <SolidColorBrush x:Key="StatusOkFg"           Color="#88ddaa"/>
                 <SolidColorBrush x:Key="StatusOkBorder"       Color="#2fa36b"/>
                 <SolidColorBrush x:Key="StatusWarnBg"         Color="#3a2e1a"/>
                 <SolidColorBrush x:Key="StatusWarnFg"         Color="#ffcc66"/>
                 <SolidColorBrush x:Key="StatusWarnBorder"     Color="#e4a11b"/>
                 <SolidColorBrush x:Key="StatusBadBg"          Color="#3a1e1e"/>
                 <SolidColorBrush x:Key="StatusBadFg"          Color="#ff8888"/>
                 <SolidColorBrush x:Key="StatusBadBorder"      Color="#d94a4a"/>
                 <SolidColorBrush x:Key="StatusInfoBg"         Color="#1e2a3e"/>
                 <SolidColorBrush x:Key="StatusInfoFg"         Color="#88aadd"/>
                 <SolidColorBrush x:Key="StatusInfoBorder"     Color="#3b6bd8"/>
                 <SolidColorBrush x:Key="StatusMutedBg"        Color="#2a2a2a"/>
                 <SolidColorBrush x:Key="StatusMutedFg"        Color="#888888"/>
                 <SolidColorBrush x:Key="StatusMutedBorder"    Color="#444444"/>
                 <SolidColorBrush x:Key="StatusAccentBg"       Color="#3a2a1e"/>
                 <SolidColorBrush x:Key="StatusAccentFg"       Color="#ffaa66"/>
                 <SolidColorBrush x:Key="StatusAccentBorder"   Color="#ff6a3d"/>
             </Application.Resources>

    <Application.Styles>
        <!-- Mode 속성 완전 삭제! -->
        <FluentTheme />   <!-- 빈 태그로만 씀 -->
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://Avalonia.Controls.TreeDataGrid/Themes/Fluent.axaml"/>
        <StyleInclude Source="/Styles/DataGridCommonStyles.axaml"/>  <!-- 프로젝트 내 경로 -->

        <!-- ══════════════════════════════════════════════════════════════
             Calendar 날짜 호버 글로우 — Windows 빛 번짐 스타일
             CalendarDayButton 내부 Border에 BoxShadow + Scale 트랜지션
             ══════════════════════════════════════════════════════════════ -->

        <!-- 날짜 셀: 스케일 트랜지션 -->
        <Style Selector="CalendarDayButton">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform"       Value="scale(1)"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.18"
                                                   Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- 날짜 셀 내부 Border: 원형 + 배경·BoxShadow(글로우) 트랜지션 -->
        <Style Selector="CalendarDayButton /template/ Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="BoxShadow"    Value="0 0 0 0 #006366F1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition       Property="Background"  Duration="0:0:0.2"  Easing="CubicEaseOut"/>
                    <BoxShadowsTransition  Property="BoxShadow"   Duration="0:0:0.28" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- 호버: 1.2× 스케일업 + 보라 반투명 배경 + 외부 글로우 번짐 -->
        <Style Selector="CalendarDayButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.22)"/>
        </Style>
        <Style Selector="CalendarDayButton:pointerover /template/ Border">
            <Setter Property="Background" Value="#556366F1"/>
            <Setter Property="BoxShadow"  Value="0 0 22 9 #8A6366F1, 0 0 9 3 #CC6366F1"/>
        </Style>

        <!-- 클릭: 살짝 눌리는 효과 -->
        <Style Selector="CalendarDayButton:pressed">
            <Setter Property="RenderTransform" Value="scale(0.88)"/>
        </Style>
        <Style Selector="CalendarDayButton:pressed /template/ Border">
            <Setter Property="Background" Value="#AA6366F1"/>
            <Setter Property="BoxShadow"  Value="0 0 10 4 #666366F1"/>
        </Style>

        <!-- 선택된 날짜: 채워진 원 + 강한 글로우 -->
        <Style Selector="CalendarDayButton:selected /template/ Border">
            <Setter Property="Background" Value="#DD6366F1"/>
            <Setter Property="BoxShadow"  Value="0 0 18 6 #AA6366F1, 0 0 7 2 #EE6366F1"/>
        </Style>

        <!-- 오늘 날짜: 청록 링 글로우 (선택 상태와 구분) -->
        <Style Selector="CalendarDayButton:today /template/ Border">
            <Setter Property="BoxShadow" Value="0 0 0 2 #CC00CFFF"/>
        </Style>
        <Style Selector="CalendarDayButton:today:pointerover /template/ Border">
            <Setter Property="BoxShadow" Value="0 0 20 8 #9900CFFF, 0 0 0 2 #EE00CFFF"/>
        </Style>

        <!-- 다른 달 날짜: 흐리게 -->
        <Style Selector="CalendarDayButton:inactive">
            <Setter Property="Opacity" Value="0.3"/>
        </Style>
        <Style Selector="CalendarDayButton:inactive:pointerover">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- 네비게이션 버튼 (< >) 호버 글로우 -->
        <Style Selector="CalendarButton">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform"       Value="scale(1)"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                    <BrushTransition               Property="Background"      Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="CalendarButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
            <Setter Property="Background"      Value="#306366F1"/>
        </Style>
        <Style Selector="CalendarButton:pressed">
            <Setter Property="RenderTransform" Value="scale(0.92)"/>
        </Style>

        <!-- CalendarItem (전체 컨테이너) 배경/보더 -->
        <Style Selector="CalendarItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderBrush"  Value="#33555577"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- ══════════════════════════════════════════════════════════════
             의미 상태 ProgressBar — Classes="ok|warn|bad|info|accent"
             wireframe v0.1 통일 색상 (채움색만 덮어씀)
             ══════════════════════════════════════════════════════════════ -->
        <Style Selector="ProgressBar.ok /template/ Border#PART_Indicator">
            <Setter Property="Background" Value="{DynamicResource StatusOkBorder}"/>
        </Style>
        <Style Selector="ProgressBar.warn /template/ Border#PART_Indicator">
            <Setter Property="Background" Value="{DynamicResource StatusWarnBorder}"/>
        </Style>
        <Style Selector="ProgressBar.bad /template/ Border#PART_Indicator">
            <Setter Property="Background" Value="{DynamicResource StatusBadBorder}"/>
        </Style>
        <Style Selector="ProgressBar.info /template/ Border#PART_Indicator">
            <Setter Property="Background" Value="{DynamicResource StatusInfoBorder}"/>
        </Style>
        <Style Selector="ProgressBar.accent /template/ Border#PART_Indicator">
            <Setter Property="Background" Value="{DynamicResource StatusAccentBorder}"/>
        </Style>

    </Application.Styles>
</Application>